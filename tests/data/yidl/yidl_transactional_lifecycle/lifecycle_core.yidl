module tests.lifecycle_core

export concept LifecycleCore

concept LifecycleCore {
    # -------------------------------------------------------------------------
    # Decorator/runtime inputs.
    # -------------------------------------------------------------------------

    property ClassId: str
    property ClassName: str
    property ClassOrder: int = 0
    property ModuleName: str = "__main__"
    property StateClassName: str
    property FacadeBaseClassName: str
    property CurrentFacadeClassName: str
    property WorkingFacadeClassName: str
    property LifecycleDefinitionParamName: str = ""
    property AnnotationsParamName: str = ""
    property TxGroupsParamName: str = ""
    property LifecycleFieldNames: object = ()

    property FieldId: str
    property FieldOwner: str
    property FieldName: str
    property FieldOrder: int
    property FieldKind: str = "field"
    property Annotation: object = object
    property Init: bool = True
    property HasDefault: bool = False
    property DefaultValue: object = None
    property DefaultValueParamName: str = ""
    property HasDefaultFactory: bool = False
    property DefaultFactory: object = None
    property DefaultFactoryParamName: str = ""
    property DefaultFactoryParamNames: object = ()
    property HasWorkingDefaultFactory: bool = False
    property WorkingDefaultFactory: object = None
    property WorkingDefaultFactoryParamName: str = ""
    property WorkingDefaultFactoryParamNames: object = ()
    property TxGroupKey: object = None
    property ValueSlotName: str = ""
    property CurrentSlotName: str = ""
    property WorkingSlotName: str = ""
    property StagedSlotName: str = ""
    property HasFreeze: bool = False
    property Freeze: object = None
    property FreezeParamName: str = ""
    property HasThaw: bool = False
    property Thaw: object = None
    property ThawParamName: str = ""
    property HasOptionalNone: bool = False

    property MethodId: str
    property MethodOwner: str
    property MethodName: str
    property MethodKind: str
    property DeclarationOrder: int = 0
    property TxIndex: int = 0

    record LifecycleClass {
        ClassId
        ClassName
        ClassOrder
        ModuleName
        StateClassName
        FacadeBaseClassName
        CurrentFacadeClassName
        WorkingFacadeClassName
        LifecycleDefinitionParamName
        AnnotationsParamName
        TxGroupsParamName
        LifecycleFieldNames
    }

    family LifecycleFieldSpec {
        common FieldId, FieldOwner, FieldName, FieldOrder, FieldKind, Annotation
        common Init, HasDefault, DefaultValue, DefaultValueParamName
        common HasDefaultFactory, DefaultFactory, DefaultFactoryParamName
        common DefaultFactoryParamNames
        common HasWorkingDefaultFactory, WorkingDefaultFactory
        common WorkingDefaultFactoryParamName, WorkingDefaultFactoryParamNames
        common TxGroupKey, ValueSlotName, CurrentSlotName, WorkingSlotName
        common StagedSlotName
        common HasFreeze, Freeze, FreezeParamName, HasThaw, Thaw, ThawParamName
        common HasOptionalNone

        variant PlainField {
        }

        variant InitVarField {
        }

        variant ClassVarField {
        }

    }

    record TransactionMethod {
        MethodId
        MethodOwner
        MethodName
        MethodKind
        TxGroupKey
        TxIndex
        DeclarationOrder
    }

    collection Classes: LifecycleClass identity ClassId many
    collection Fields: LifecycleFieldSpec identity FieldId many
    collection TransactionMethods: TransactionMethod identity MethodId many
    computed collection PlainFields: LifecycleFieldSpec from Fields where FieldKind == "field"
    computed collection InitVarFields: LifecycleFieldSpec from Fields where FieldKind == "initvar"
    computed collection ClassVarFields: LifecycleFieldSpec from Fields where FieldKind == "classvar"
    computed collection CommitOrderKeyProviders: TransactionMethod from TransactionMethods where MethodKind == "commit_order_key"
    computed collection CommitValidators: TransactionMethod from TransactionMethods where MethodKind == "validate_commit"
    computed collection BeforeCommitHooks: TransactionMethod from TransactionMethods where MethodKind == "before_commit"
    computed collection AfterCommitHooks: TransactionMethod from TransactionMethods where MethodKind == "after_commit"
    computed collection AfterRollbackHooks: TransactionMethod from TransactionMethods where MethodKind == "after_rollback"

    # -------------------------------------------------------------------------
    # Facade facts.
    # -------------------------------------------------------------------------

    property FacadeId: str
    property FacadeOwner: str
    property FacadeKind: str
    property FacadeMode: str
    property FacadeClassName: str
    property FacadeOrder: int = 0

    property OwnerFacadeId: str
    property TargetFacadeId: str
    property ExposureOrder: int = 0

    record FacadeClass {
        FacadeOwner
        FacadeId
        FacadeKind
        FacadeMode
        FacadeClassName
        FacadeOrder
    }

    record FacadeExposure {
        FacadeOwner
        OwnerFacadeId
        FieldName
        TargetFacadeId
        ExposureOrder
    }

    collection FacadeClasses: FacadeClass identity (FacadeOwner, FacadeId) many
    collection FacadeExposures: FacadeExposure identity (FacadeOwner, OwnerFacadeId, FieldName) many

    # -------------------------------------------------------------------------
    # Init and generated assignment facts.
    # -------------------------------------------------------------------------

    property InitParameterId: str
    property InitParameterOwner: str
    property InitParameterName: str
    property InitParameterOrder: int = 0
    property InitParameterKind: str = "field"

    property InitAssignmentId: str
    property InitAssignmentOwner: str
    property InitAssignmentFieldId: str
    property InitAssignmentFieldName: str
    property InitAssignmentOrder: int = 0
    property InitAssignmentKind: str = "plain"

    property ClassVarAssignmentId: str
    property ClassVarAssignmentOwner: str
    property ClassVarAssignmentName: str
    property ClassVarAssignmentOrder: int = 0

    record InitParameter {
        InitParameterId
        InitParameterOwner
        InitParameterName
        InitParameterOrder
        InitParameterKind
    }

    record InitAssignment {
        InitAssignmentId
        InitAssignmentOwner
        InitAssignmentFieldId
        InitAssignmentFieldName
        InitAssignmentOrder
        InitAssignmentKind
    }

    record ClassVarAssignment {
        ClassVarAssignmentId
        ClassVarAssignmentOwner
        ClassVarAssignmentName
        ClassVarAssignmentOrder
    }

    collection InitParameters: InitParameter identity InitParameterId many
    collection InitAssignments: InitAssignment identity InitAssignmentId many
    collection ClassVarAssignments: ClassVarAssignment identity ClassVarAssignmentId many

    # -------------------------------------------------------------------------
    # Core generated module/class skeleton.
    # -------------------------------------------------------------------------

    resource ModuleRoot = code $[
        from __future__ import annotations

        import weakref

        from yidl.runtime.lifecycle import _HAS_DEFAULT_FACTORY
        from yidl.runtime.transaction_yidl import DEFAULT_TRANSACTION
        from yidl.runtime.transaction_yidl import TransactionManager


        VOID = object()


        def build_lifecycle_class(decorated_cls, builder_params__astichi_param_hole__):
            astichi_hole(function_body)
            astichi_hole(return_statement)
    ]$

    resource BuilderParam = template $[
        def astichi_params(*, value_name__astichi_arg__):
            pass
    ]$

    resource TransactionManagerParam = template $[
        def astichi_params(*, transaction_manager=None):
            pass
    ]$

    resource StateSlotEntry = template $[
        astichi_bind_external(slot_name)
    ]$

    resource InitParamRequired = template $[
        def astichi_params(param_name__astichi_arg__: astichi_bind_external(annotation)):
            pass
    ]$

    resource InitParamDefault = template $[
        def astichi_params(
            param_name__astichi_arg__: astichi_bind_external(annotation)
            = default_value_name__astichi_arg__
        ):
            pass
    ]$

    resource PlainStateAssignment = template $[
        astichi_pass(state, outer_bind=True).astichi_ref(external=state_slot)._ = astichi_pass(
            init_value_name__astichi_arg__,
            outer_bind=True,
        )
    ]$

    resource InitVarLocalDefaultAssignment = template $[
        init_value_name__astichi_arg__ = astichi_pass(
            default_value_name__astichi_arg__,
            outer_bind=True,
        )
    ]$

    resource PlainProperty = template $[
        @property
        def property_getter_name__astichi_arg__(self):
            return self._y_state.astichi_ref(external=state_slot)

        @property_setter_target_name__astichi_arg__.setter
        def property_setter_name__astichi_arg__(self, value):
            self._y_state.astichi_ref(external=state_slot)._ = value
    ]$

    resource ClassVarDefaultAssignment = template $[
        classvar_name__astichi_arg__ = astichi_pass(
            classvar_value_name__astichi_arg__,
            outer_bind=True,
        )
    ]$

    resource CommitOrderKeyBranch = template $[
        match astichi_pass(tx_index, outer_bind=True):
            case _ if astichi_pass(tx_index, outer_bind=True) == astichi_bind_external(tx_index_value):
                return astichi_pass(
                    self,
                    outer_bind=True,
                )._y_get_default_facade().astichi_ref(external=method_name)()
    ]$

    resource RequiresValidationBranch = template $[
        match astichi_pass(tx_index, outer_bind=True):
            case _ if astichi_pass(tx_index, outer_bind=True) == astichi_bind_external(tx_index_value):
                return True
    ]$

    resource ValidateCommitBranch = template $[
        match astichi_pass(tx_index, outer_bind=True):
            case _ if astichi_pass(tx_index, outer_bind=True) == astichi_bind_external(tx_index_value):
                result = astichi_pass(
                    self,
                    outer_bind=True,
                )._y_get_default_facade().astichi_ref(external=method_name)()
                if result is False:
                    return False
    ]$

    resource TransactionHookCall = template $[
        match astichi_pass(tx_index, outer_bind=True):
            case _ if astichi_pass(tx_index, outer_bind=True) == astichi_bind_external(tx_index_value):
                astichi_pass(
                    self,
                    outer_bind=True,
                )._y_get_default_facade().astichi_ref(external=method_name)()
    ]$

    resource ClassBundle = template $[
        class state_class_decl_name__astichi_arg__:
            __slots__ = (
                "_y_transaction_manager",
                "_y_default_ref",
                "_y_current_ref",
                "_y_working_ref",
                *astichi_hole(state_slots),
                "_y_working_tx_ids",
            )
            __yidl_tx_index_to_key__ = astichi_pass(
                tx_groups_for_index_name__astichi_arg__,
                outer_bind=True,
            )
            __yidl_tx_key_to_index__ = {
                key: index for index, key in enumerate(
                    astichi_pass(tx_groups_for_map_name__astichi_arg__, outer_bind=True)
                )
            }

            def _y_get_default_facade(self):
                ref = self._y_default_ref
                facade = None if ref is None else ref()
                if facade is None:
                    facade = object.__new__(default_facade_class_ref__astichi_arg__)
                    object.__setattr__(facade, "_y_state", self)
                    current_ref = self._y_current_ref
                    working_ref = self._y_working_ref
                    object.__setattr__(
                        facade,
                        "_y_current_facade",
                        None if current_ref is None else current_ref(),
                    )
                    object.__setattr__(
                        facade,
                        "_y_working_facade",
                        None if working_ref is None else working_ref(),
                    )
                    self._y_default_ref = weakref.ref(facade)
                return facade

            def _y_get_current_facade(self):
                ref = self._y_current_ref
                facade = None if ref is None else ref()
                if facade is None:
                    facade = object.__new__(current_facade_class_ref__astichi_arg__)
                    object.__setattr__(facade, "_y_state", self)
                    self._y_current_ref = weakref.ref(facade)
                    default_ref = self._y_default_ref
                    default = None if default_ref is None else default_ref()
                    if default is not None:
                        object.__setattr__(default, "_y_current_facade", facade)
                return facade

            def _y_get_working_facade(self):
                ref = self._y_working_ref
                facade = None if ref is None else ref()
                if facade is None:
                    facade = object.__new__(working_facade_class_ref__astichi_arg__)
                    object.__setattr__(facade, "_y_state", self)
                    self._y_working_ref = weakref.ref(facade)
                    default_ref = self._y_default_ref
                    default = None if default_ref is None else default_ref()
                    if default is not None:
                        object.__setattr__(default, "_y_working_facade", facade)
                return facade

            def _y_require_active_transaction(self, tx_index):
                tx_key = self.__yidl_tx_index_to_key__[tx_index]
                transaction = self._y_transaction_manager.active_transaction_for(tx_key)
                if transaction is None:
                    if self._y_working_tx_ids[tx_index] is not None:
                        raise RuntimeError(
                            "stale yidl working value without an active transaction"
                        )
                    raise RuntimeError("writes require an active yidl transaction")
                existing_tx_id = self._y_working_tx_ids[tx_index]
                if existing_tx_id is not None and existing_tx_id != transaction.tx_id:
                    raise RuntimeError(
                        "working value belongs to a different yidl transaction"
                    )
                return transaction

            def _y_ensure_working_transaction(self, tx_index):
                transaction = self._y_require_active_transaction(tx_index)
                if self._y_working_tx_ids[tx_index] is None:
                    tx_key = self.__yidl_tx_index_to_key__[tx_index]
                    self._y_working_tx_ids[tx_index] = (
                        self._y_transaction_manager.enlist(self, tx_key)
                    )
                return transaction

            def commit_order_key_for(self, tx_key=DEFAULT_TRANSACTION):
                tx_index = self.__yidl_tx_key_to_index__[tx_key]
                astichi_hole(commit_order_key_body)
                return ()

            def requires_validation_for(self, tx_key=DEFAULT_TRANSACTION):
                tx_index = self.__yidl_tx_key_to_index__[tx_key]
                astichi_hole(requires_validation_body)
                return False

            def validate_commit_for(self, tx_key=DEFAULT_TRANSACTION):
                tx_index = self.__yidl_tx_key_to_index__[tx_key]
                astichi_hole(validate_commit_body)
                return True

            def _prepare_commit_tx_by_key(self, tx_key=DEFAULT_TRANSACTION, tx_token=None):
                tx_index = self.__yidl_tx_key_to_index__[tx_key]
                if self._y_working_tx_ids[tx_index] != tx_token:
                    raise RuntimeError("stale yidl transaction token")
                astichi_hole(before_commit_body)
                astichi_hole(prepare_commit_transaction_dispatch_body)
                return self._y_get_default_facade()

            def _apply_prepared_commit_tx_by_key(self, tx_key=DEFAULT_TRANSACTION, tx_token=None):
                tx_index = self.__yidl_tx_key_to_index__[tx_key]
                if self._y_working_tx_ids[tx_index] != tx_token:
                    raise RuntimeError("stale yidl transaction token")
                astichi_hole(commit_transaction_dispatch_body)
                astichi_hole(commit_transaction_body)
                self._y_working_tx_ids[tx_index] = None
                return self._y_get_default_facade()

            def _after_commit_tx_by_key(self, tx_key=DEFAULT_TRANSACTION, tx_token=None):
                del tx_token
                tx_index = self.__yidl_tx_key_to_index__[tx_key]
                astichi_hole(after_commit_body)
                return self._y_get_default_facade()

            def _rollback_tx_by_key(self, tx_key=DEFAULT_TRANSACTION, tx_token=None):
                tx_index = self.__yidl_tx_key_to_index__[tx_key]
                del tx_token
                astichi_hole(rollback_transaction_dispatch_body)
                astichi_hole(rollback_transaction_body)
                self._y_working_tx_ids[tx_index] = None
                return self._y_get_default_facade()

            def _after_rollback_tx_by_key(self, tx_key=DEFAULT_TRANSACTION, tx_token=None):
                del tx_token
                tx_index = self.__yidl_tx_key_to_index__[tx_key]
                astichi_hole(after_rollback_body)
                return self._y_get_default_facade()

            astichi_hole(commit_transaction_helpers)
            astichi_hole(rollback_transaction_helpers)


        class facade_base_decl_name__astichi_arg__(
            astichi_pass(decorated_cls, outer_bind=True)
        ):
            __slots__ = (
                ("_y_state",)
                if hasattr(astichi_pass(decorated_cls, outer_bind=True), "__weakref__")
                else ("_y_state", "__weakref__")
            )
            _y_lifecycle_field_names = frozenset(
                astichi_bind_external(lifecycle_field_names)
            )

            def __setattr__(self, name, value):
                if name in self._y_lifecycle_field_names:
                    descriptor = getattr(type(self), name, None)
                    if descriptor is None or not hasattr(descriptor, "__set__"):
                        raise AttributeError(
                            f"lifecycle field {name!r} is not assignable"
                        )
                    descriptor.__set__(self, value)
                    return
                if name.startswith("_y_") or name.startswith("__yidl_"):
                    raise AttributeError(
                        f"{name!r} is reserved for generated lifecycle state"
                    )
                object.__setattr__(self, name, value)

            def __delattr__(self, name):
                if name in self._y_lifecycle_field_names:
                    raise AttributeError(f"lifecycle field {name!r} cannot be deleted")
                if name.startswith("_y_") or name.startswith("__yidl_"):
                    raise AttributeError(
                        f"{name!r} is reserved for generated lifecycle state"
                    )
                object.__delattr__(self, name)

            @property
            def default(self):
                return self._y_state._y_get_default_facade()

            @property
            def current(self):
                return self._y_state._y_get_current_facade()

            @property
            def working(self):
                return self._y_state._y_get_working_facade()

            def begin(self, *tx_keys):
                return self._y_state._y_transaction_manager.begin(*tx_keys)

            def validate(self, *tx_keys):
                return self._y_state._y_transaction_manager.validate(*tx_keys)

            def commit_only(self, *tx_keys):
                return self._y_state._y_transaction_manager.commit_only(*tx_keys)

            def commit(self, *tx_keys):
                return self._y_state._y_transaction_manager.commit(*tx_keys)

            def rollback(self, *tx_keys):
                return self._y_state._y_transaction_manager.rollback(*tx_keys)

            astichi_hole(facade_base_body)
            astichi_hole(facade_properties)


        class default_facade_class_decl_name__astichi_arg__(
            facade_base_default_base_name__astichi_arg__
        ):
            __slots__ = ("_y_current_facade", "_y_working_facade")
            __annotations__ = astichi_pass(
                annotations_name__astichi_arg__,
                outer_bind=True,
            )
            __yidl_lifecycle_generated__ = True
            __yidl_lifecycle_user_class__ = astichi_pass(
                decorated_cls,
                outer_bind=True,
            )
            __yidl_lifecycle_definition__ = astichi_pass(
                lifecycle_definition_name__astichi_arg__,
                outer_bind=True,
            )
            __yidl_tx_index_to_key__ = astichi_pass(
                tx_groups_for_class_index_name__astichi_arg__,
                outer_bind=True,
            )
            __yidl_tx_key_to_index__ = {
                key: index for index, key in enumerate(
                    astichi_pass(
                        tx_groups_for_class_map_name__astichi_arg__,
                        outer_bind=True,
                    )
                )
            }

            astichi_hole(default_facade_properties)

            def __init__(self, init_params__astichi_param_hole__):
                state = object.__new__(state_class_ref__astichi_arg__)
                object.__setattr__(self, "_y_state", state)
                object.__setattr__(self, "_y_current_facade", None)
                object.__setattr__(self, "_y_working_facade", None)
                state._y_transaction_manager = transaction_manager or TransactionManager(
                    tx_groups=tuple(
                        group for group in astichi_pass(
                            tx_groups_for_manager_name__astichi_arg__,
                            outer_bind=True,
                        )
                        if group != DEFAULT_TRANSACTION
                    )
                )
                state._y_default_ref = weakref.ref(self)
                state._y_current_ref = None
                state._y_working_ref = None
                astichi_hole(state_init_body)
                state._y_working_tx_ids = [
                    None
                    for _group in astichi_pass(
                        tx_groups_for_slots_name__astichi_arg__,
                        outer_bind=True,
                    )
                ]


        class current_facade_class_decl_name__astichi_arg__(
            facade_base_current_base_name__astichi_arg__
        ):
            __slots__ = ()
            astichi_hole(current_facade_properties)


        class working_facade_class_decl_name__astichi_arg__(
            facade_base_working_base_name__astichi_arg__
        ):
            __slots__ = ()
            astichi_hole(working_facade_properties)
    ]$ {
        keep DEFAULT_TRANSACTION, TransactionManager, VOID, weakref
        keep _HAS_DEFAULT_FACTORY
    }

    resource ReturnClass = template $[
        return_class_name_ref__astichi_arg__.__name__ = astichi_pass(
            decorated_cls,
            outer_bind=True,
        ).__name__
        return_class_qualname_ref__astichi_arg__.__qualname__ = astichi_pass(
            decorated_cls,
            outer_bind=True,
        ).__qualname__
        return_class_module_ref__astichi_arg__.__module__ = astichi_pass(
            decorated_cls,
            outer_bind=True,
        ).__module__
        return return_class_result_ref__astichi_arg__
    ]$

    resource PassStatement = template $[
        pass
    ]$

    contribution LifecycleDefinitionBuilderParam = BuilderParam {
        as LifecycleDefinitionBuilderParam
        index ClassOrder
        order ClassOrder

        target builder_params {
            build /Root
        }

        ident value_name = LifecycleDefinitionParamName
    }

    contribution AnnotationsBuilderParam = BuilderParam {
        as AnnotationsBuilderParam
        index ClassOrder
        order ClassOrder

        target builder_params {
            build /Root
        }

        ident value_name = AnnotationsParamName
    }

    contribution TxGroupsBuilderParam = BuilderParam {
        as TxGroupsBuilderParam
        index ClassOrder
        order ClassOrder

        target builder_params {
            build /Root
        }

        ident value_name = TxGroupsParamName
    }

    contribution FieldDefaultBuilderParam = BuilderParam {
        as FieldDefaultBuilderParam
        index FieldOrder
        order FieldOrder

        target builder_params {
            build /Root
        }

        ident value_name = DefaultValueParamName
    }

    contribution FacadeBaseBodyPass = PassStatement {
        as FacadeBaseBodyPass
        index 0
        order 0

        target facade_base_body {
            build /ClassDef
        }
    }

    contribution FacadePropertiesPass = PassStatement {
        as FacadePropertiesPass
        index 0
        order 0

        target facade_properties {
            build /ClassDef
        }
    }

    contribution DefaultFacadePropertiesPass = PassStatement {
        as DefaultFacadePropertiesPass
        index 0
        order 0

        target default_facade_properties {
            build /ClassDef
        }
    }

    contribution CurrentFacadePropertiesPass = PassStatement {
        as CurrentFacadePropertiesPass
        index 0
        order 0

        target current_facade_properties {
            build /ClassDef
        }
    }

    contribution WorkingFacadePropertiesPass = PassStatement {
        as WorkingFacadePropertiesPass
        index 0
        order 0

        target working_facade_properties {
            build /ClassDef
        }
    }

    contribution StateInitBodyPass = PassStatement {
        as StateInitBodyPass
        index 0
        order 0

        target state_init_body {
            build /ClassDef
        }
    }

    contribution CommitTransactionBodyPass = PassStatement {
        as CommitTransactionBodyPass
        index 0
        order 0

        target commit_transaction_body {
            build /ClassDef
        }
    }

    contribution CommitTransactionDispatchBodyPass = PassStatement {
        as CommitTransactionDispatchBodyPass
        index 0
        order 0

        target commit_transaction_dispatch_body {
            build /ClassDef
        }
    }

    contribution CommitTransactionHelpersPass = PassStatement {
        as CommitTransactionHelpersPass
        index 0
        order 0

        target commit_transaction_helpers {
            build /ClassDef
        }
    }

    contribution RollbackTransactionHelpersPass = PassStatement {
        as RollbackTransactionHelpersPass
        index 0
        order 0

        target rollback_transaction_helpers {
            build /ClassDef
        }
    }

    contribution PrepareCommitTransactionDispatchBodyPass = PassStatement {
        as PrepareCommitTransactionDispatchBodyPass
        index 0
        order 0

        target prepare_commit_transaction_dispatch_body {
            build /ClassDef
        }
    }

    contribution RollbackTransactionBodyPass = PassStatement {
        as RollbackTransactionBodyPass
        index 0
        order 0

        target rollback_transaction_body {
            build /ClassDef
        }
    }

    contribution RollbackTransactionDispatchBodyPass = PassStatement {
        as RollbackTransactionDispatchBodyPass
        index 0
        order 0

        target rollback_transaction_dispatch_body {
            build /ClassDef
        }
    }

    contribution CommitOrderKeyBodyPass = PassStatement {
        as CommitOrderKeyBodyPass
        index 0
        order 0

        target commit_order_key_body {
            build /ClassDef
        }
    }

    contribution RequiresValidationBodyPass = PassStatement {
        as RequiresValidationBodyPass
        index 0
        order 0

        target requires_validation_body {
            build /ClassDef
        }
    }

    contribution ValidateCommitBodyPass = PassStatement {
        as ValidateCommitBodyPass
        index 0
        order 0

        target validate_commit_body {
            build /ClassDef
        }
    }

    contribution BeforeCommitBodyPass = PassStatement {
        as BeforeCommitBodyPass
        index 0
        order 0

        target before_commit_body {
            build /ClassDef
        }
    }

    contribution AfterCommitBodyPass = PassStatement {
        as AfterCommitBodyPass
        index 0
        order 0

        target after_commit_body {
            build /ClassDef
        }
    }

    contribution AfterRollbackBodyPass = PassStatement {
        as AfterRollbackBodyPass
        index 0
        order 0

        target after_rollback_body {
            build /ClassDef
        }
    }

    contribution ReturnClassContribution = ReturnClass {
        as ReturnClass
        index ClassOrder
        order ClassOrder

        target return_statement {
            build /Root
        }

        ident return_class_name_ref = ClassName
        ident return_class_qualname_ref = ClassName
        ident return_class_module_ref = ClassName
        ident return_class_result_ref = ClassName
    }

    contribution TransactionManagerInitParam = TransactionManagerParam {
        as TransactionManagerInitParam
        index ClassOrder
        order 0

        target init_params {
            build /ClassDef
        }
    }

    contribution PlainStateSlot = StateSlotEntry {
        as PlainStateSlot
        index FieldOrder
        order FieldOrder

        target state_slots {
            build /ClassDef
        }

        external slot_name = ValueSlotName
    }

    contribution PlainInitParamRequired = InitParamRequired {
        as PlainInitParam
        index FieldOrder
        order FieldOrder

        target init_params {
            build /ClassDef
        }

        ident param_name = FieldName
        external annotation = Annotation
    }

    contribution PlainInitParamDefault = InitParamDefault {
        as PlainInitParam
        index FieldOrder
        order FieldOrder

        target init_params {
            build /ClassDef
        }

        ident param_name = FieldName
        external annotation = Annotation
        ident default_value_name = DefaultValueParamName
    }

    contribution InitVarParamRequired = InitParamRequired {
        as InitVarParam
        index FieldOrder
        order FieldOrder

        target init_params {
            build /ClassDef
        }

        ident param_name = FieldName
        external annotation = Annotation
    }

    contribution InitVarParamDefault = InitParamDefault {
        as InitVarParam
        index FieldOrder
        order FieldOrder

        target init_params {
            build /ClassDef
        }

        ident param_name = FieldName
        external annotation = Annotation
        ident default_value_name = DefaultValueParamName
    }

    contribution InitVarLocalDefault = InitVarLocalDefaultAssignment {
        as InitVarLocalDefault
        index FieldOrder
        order FieldOrder

        target state_init_body {
            build /ClassDef
        }

        ident init_value_name = FieldName
        ident default_value_name = DefaultValueParamName
    }

    contribution PlainInitAssignment = PlainStateAssignment {
        as PlainInitAssignment
        index FieldOrder
        order FieldOrder

        target state_init_body {
            build /ClassDef
        }

        ident init_value_name = FieldName
        external state_slot = ValueSlotName
    }

    contribution PlainDefaultAssignment = PlainStateAssignment {
        as PlainDefaultAssignment
        index FieldOrder
        order FieldOrder

        target state_init_body {
            build /ClassDef
        }

        ident init_value_name = DefaultValueParamName
        external state_slot = ValueSlotName
    }

    contribution PlainFieldProperty = PlainProperty {
        as PlainFieldProperty
        index FieldOrder
        order FieldOrder

        target facade_properties {
            build /ClassDef
        }

        ident property_getter_name = FieldName
        ident property_setter_target_name = FieldName
        ident property_setter_name = FieldName
        external state_slot = ValueSlotName
    }

    contribution ClassVarDefault = ClassVarDefaultAssignment {
        as ClassVarDefault
        index FieldOrder
        order FieldOrder

        target facade_base_body {
            build /ClassDef
        }

        ident classvar_name = FieldName
        ident classvar_value_name = DefaultValueParamName
    }

    contribution CommitOrderKeyBranchContribution = CommitOrderKeyBranch {
        as CommitOrderKeyBranch
        index DeclarationOrder
        order DeclarationOrder

        target commit_order_key_body {
            build /ClassDef
        }

        external method_name = MethodName
        external tx_index_value = TxIndex
    }

    contribution RequiresValidationBranchContribution = RequiresValidationBranch {
        as RequiresValidationBranch
        index DeclarationOrder
        order DeclarationOrder

        target requires_validation_body {
            build /ClassDef
        }

        external tx_index_value = TxIndex
    }

    contribution ValidateCommitBranchContribution = ValidateCommitBranch {
        as ValidateCommitBranch
        index DeclarationOrder
        order DeclarationOrder

        target validate_commit_body {
            build /ClassDef
        }

        external method_name = MethodName
        external tx_index_value = TxIndex
    }

    contribution BeforeCommitHookContribution = TransactionHookCall {
        as BeforeCommitHook
        index DeclarationOrder
        order DeclarationOrder

        target before_commit_body {
            build /ClassDef
        }

        external method_name = MethodName
        external tx_index_value = TxIndex
    }

    contribution AfterCommitHookContribution = TransactionHookCall {
        as AfterCommitHook
        index DeclarationOrder
        order DeclarationOrder

        target after_commit_body {
            build /ClassDef
        }

        external method_name = MethodName
        external tx_index_value = TxIndex
    }

    contribution AfterRollbackHookContribution = TransactionHookCall {
        as AfterRollbackHook
        index DeclarationOrder
        order DeclarationOrder

        target after_rollback_body {
            build /ClassDef
        }

        external method_name = MethodName
        external tx_index_value = TxIndex
    }

    contribution CoreClassDefinition = CoreClassProduction {
        as ClassDef
        index ClassOrder
        order ClassOrder

        target function_body {
            build /Root
        }
    }

    matcher BuilderParamContributions(lifecycle_class: Classes) -> contribution {
        default -> LifecycleDefinitionBuilderParam
    }

    matcher AnnotationsBuilderParamContributions(lifecycle_class: Classes) -> contribution {
        default -> AnnotationsBuilderParam
    }

    matcher TxGroupsBuilderParamContributions(lifecycle_class: Classes) -> contribution {
        default -> TxGroupsBuilderParam
    }

    matcher ReturnClassContributions(lifecycle_class: Classes) -> contribution {
        default -> ReturnClassContribution
    }

    matcher TransactionManagerInitParamContributions(lifecycle_class: Classes) -> contribution {
        default -> TransactionManagerInitParam
    }

    matcher FacadeBaseBodyPassContributions(lifecycle_class: Classes) -> contribution {
        default -> FacadeBaseBodyPass
    }

    matcher FacadePropertiesPassContributions(lifecycle_class: Classes) -> contribution {
        default -> FacadePropertiesPass
    }

    matcher DefaultFacadePropertiesPassContributions(lifecycle_class: Classes) -> contribution {
        default -> DefaultFacadePropertiesPass
    }

    matcher CurrentFacadePropertiesPassContributions(lifecycle_class: Classes) -> contribution {
        default -> CurrentFacadePropertiesPass
    }

    matcher WorkingFacadePropertiesPassContributions(lifecycle_class: Classes) -> contribution {
        default -> WorkingFacadePropertiesPass
    }

    matcher StateInitBodyPassContributions(lifecycle_class: Classes) -> contribution {
        default -> StateInitBodyPass
    }

    matcher CommitTransactionBodyPassContributions(lifecycle_class: Classes) -> contribution {
        default -> CommitTransactionBodyPass
    }

    matcher CommitTransactionDispatchBodyPassContributions(lifecycle_class: Classes) -> contribution {
        default -> CommitTransactionDispatchBodyPass
    }

    matcher CommitTransactionHelpersPassContributions(lifecycle_class: Classes) -> contribution {
        default -> CommitTransactionHelpersPass
    }

    matcher RollbackTransactionHelpersPassContributions(lifecycle_class: Classes) -> contribution {
        default -> RollbackTransactionHelpersPass
    }

    matcher PrepareCommitTransactionDispatchBodyPassContributions(lifecycle_class: Classes) -> contribution {
        default -> PrepareCommitTransactionDispatchBodyPass
    }

    matcher RollbackTransactionBodyPassContributions(lifecycle_class: Classes) -> contribution {
        default -> RollbackTransactionBodyPass
    }

    matcher RollbackTransactionDispatchBodyPassContributions(lifecycle_class: Classes) -> contribution {
        default -> RollbackTransactionDispatchBodyPass
    }

    matcher CommitOrderKeyBodyPassContributions(lifecycle_class: Classes) -> contribution {
        default -> CommitOrderKeyBodyPass
    }

    matcher RequiresValidationBodyPassContributions(lifecycle_class: Classes) -> contribution {
        default -> RequiresValidationBodyPass
    }

    matcher ValidateCommitBodyPassContributions(lifecycle_class: Classes) -> contribution {
        default -> ValidateCommitBodyPass
    }

    matcher BeforeCommitBodyPassContributions(lifecycle_class: Classes) -> contribution {
        default -> BeforeCommitBodyPass
    }

    matcher AfterCommitBodyPassContributions(lifecycle_class: Classes) -> contribution {
        default -> AfterCommitBodyPass
    }

    matcher AfterRollbackBodyPassContributions(lifecycle_class: Classes) -> contribution {
        default -> AfterRollbackBodyPass
    }

    matcher PlainStateSlotContributions(field: PlainFields) -> contribution {
        default -> PlainStateSlot
    }

    matcher InitVarLocalDefaultContributions(field: InitVarFields) -> contribution {
        rule default_value when Init == False
                           and HasDefault == True
                           and HasDefaultFactory == False
                           -> InitVarLocalDefault
    }

    matcher PlainInitAssignmentContributions(field: PlainFields) -> contribution {
        rule init_field when Init == True
                        and HasDefaultFactory == False
                        -> PlainInitAssignment
        rule default_value when Init == False
                           and HasDefault == True
                           and HasDefaultFactory == False
                           -> PlainDefaultAssignment
    }

    matcher PlainPropertyContributions(field: PlainFields) -> contribution {
        default -> PlainFieldProperty
    }

    matcher ClassVarDefaultContributions(field: ClassVarFields) -> contribution {
        rule has_default when HasDefault == True -> ClassVarDefault
    }

    matcher CommitOrderKeyContributions(method: CommitOrderKeyProviders) -> contribution {
        default -> CommitOrderKeyBranchContribution
    }

    matcher RequiresValidationContributions(method: CommitValidators) -> contribution {
        default -> RequiresValidationBranchContribution
    }

    matcher ValidateCommitContributions(method: CommitValidators) -> contribution {
        default -> ValidateCommitBranchContribution
    }

    matcher BeforeCommitHookContributions(method: BeforeCommitHooks) -> contribution {
        default -> BeforeCommitHookContribution
    }

    matcher AfterCommitHookContributions(method: AfterCommitHooks) -> contribution {
        default -> AfterCommitHookContribution
    }

    matcher AfterRollbackHookContributions(method: AfterRollbackHooks) -> contribution {
        default -> AfterRollbackHookContribution
    }

    matcher FieldDefaultBuilderParamContributions(field: Fields) -> contribution {
        rule has_default when HasDefault == True -> FieldDefaultBuilderParam
    }

    matcher CoreClassDefinitionContributions(lifecycle_class: Classes) -> contribution {
        default -> CoreClassDefinition
    }

    matcher PlainInitParamContributions(field: PlainFields) -> contribution {
        rule required when Init == True
                      and HasDefault == False
                      and HasDefaultFactory == False
                      -> PlainInitParamRequired
        rule default_value when Init == True
                           and HasDefault == True
                           and HasDefaultFactory == False
                           -> PlainInitParamDefault
    }

    matcher InitVarParamContributions(field: InitVarFields) -> contribution {
        rule required when Init == True
                      and HasDefault == False
                      and HasDefaultFactory == False
                      -> InitVarParamRequired
        rule default_value when Init == True
                           and HasDefault == True
                           and HasDefaultFactory == False
                           -> InitVarParamDefault
    }

    production CoreModuleProduction -> composable {
        root Root = ModuleRoot

        apply lifecycle_definition_params
            from lifecycle_class: Classes
            using BuilderParamContributions

        apply annotations_params
            from lifecycle_class: Classes
            using AnnotationsBuilderParamContributions

        apply tx_groups_params
            from lifecycle_class: Classes
            using TxGroupsBuilderParamContributions

        apply field_default_params
            from field: Fields
            using FieldDefaultBuilderParamContributions

        apply classes
            from lifecycle_class: Classes
            using CoreClassDefinitionContributions

        apply return_class
            from lifecycle_class: Classes
            using ReturnClassContributions
    }

    production CoreClassProduction(lifecycle_class: Classes) -> composable {
        root ClassDef = ClassBundle {
            ident state_class_decl_name = StateClassName
            ident state_class_ref = StateClassName
            ident default_facade_class_decl_name = ClassName
            ident default_facade_class_ref = ClassName
            ident facade_base_decl_name = FacadeBaseClassName
            ident facade_base_default_base_name = FacadeBaseClassName
            ident facade_base_current_base_name = FacadeBaseClassName
            ident facade_base_working_base_name = FacadeBaseClassName
            ident current_facade_class_decl_name = CurrentFacadeClassName
            ident current_facade_class_ref = CurrentFacadeClassName
            ident working_facade_class_decl_name = WorkingFacadeClassName
            ident working_facade_class_ref = WorkingFacadeClassName
            ident tx_groups_for_index_name = TxGroupsParamName
            ident tx_groups_for_map_name = TxGroupsParamName
            ident tx_groups_for_class_index_name = TxGroupsParamName
            ident tx_groups_for_class_map_name = TxGroupsParamName
            ident tx_groups_for_manager_name = TxGroupsParamName
            ident tx_groups_for_slots_name = TxGroupsParamName
            ident lifecycle_definition_name = LifecycleDefinitionParamName
            ident annotations_name = AnnotationsParamName
            external lifecycle_field_names = LifecycleFieldNames
        }

        apply state_slots
            from field: PlainFields
            where FieldOwner == ClassId
            using PlainStateSlotContributions

        apply transaction_manager_param
            using TransactionManagerInitParamContributions

        apply facade_base_body_pass
            using FacadeBaseBodyPassContributions

        apply facade_properties_pass
            using FacadePropertiesPassContributions

        apply default_facade_properties_pass
            using DefaultFacadePropertiesPassContributions

        apply current_facade_properties_pass
            using CurrentFacadePropertiesPassContributions

        apply working_facade_properties_pass
            using WorkingFacadePropertiesPassContributions

        apply state_init_body_pass
            using StateInitBodyPassContributions

        apply commit_transaction_body_pass
            using CommitTransactionBodyPassContributions

        apply commit_transaction_dispatch_body_pass
            using CommitTransactionDispatchBodyPassContributions

        apply commit_transaction_helpers_pass
            using CommitTransactionHelpersPassContributions

        apply rollback_transaction_helpers_pass
            using RollbackTransactionHelpersPassContributions

        apply prepare_commit_transaction_dispatch_body_pass
            using PrepareCommitTransactionDispatchBodyPassContributions

        apply rollback_transaction_body_pass
            using RollbackTransactionBodyPassContributions

        apply rollback_transaction_dispatch_body_pass
            using RollbackTransactionDispatchBodyPassContributions

        apply commit_order_key_body_pass
            using CommitOrderKeyBodyPassContributions

        apply requires_validation_body_pass
            using RequiresValidationBodyPassContributions

        apply validate_commit_body_pass
            using ValidateCommitBodyPassContributions

        apply before_commit_body_pass
            using BeforeCommitBodyPassContributions

        apply after_commit_body_pass
            using AfterCommitBodyPassContributions

        apply after_rollback_body_pass
            using AfterRollbackBodyPassContributions

        apply classvars
            from field: ClassVarFields
            where FieldOwner == ClassId
            using ClassVarDefaultContributions

        apply commit_order_keys
            from method: CommitOrderKeyProviders
            where MethodOwner == ClassId
            using CommitOrderKeyContributions

        apply validation_flags
            from method: CommitValidators
            where MethodOwner == ClassId
            using RequiresValidationContributions

        apply validators
            from method: CommitValidators
            where MethodOwner == ClassId
            using ValidateCommitContributions

        apply before_commit_hooks
            from method: BeforeCommitHooks
            where MethodOwner == ClassId
            using BeforeCommitHookContributions

        apply after_commit_hooks
            from method: AfterCommitHooks
            where MethodOwner == ClassId
            using AfterCommitHookContributions

        apply after_rollback_hooks
            from method: AfterRollbackHooks
            where MethodOwner == ClassId
            using AfterRollbackHookContributions

        apply plain_init_params
            from field: PlainFields
            where FieldOwner == ClassId
            using PlainInitParamContributions

        apply initvar_params
            from field: InitVarFields
            where FieldOwner == ClassId
            using InitVarParamContributions

        apply initvar_local_defaults
            from field: InitVarFields
            where FieldOwner == ClassId
            using InitVarLocalDefaultContributions

        apply plain_init_assignments
            from field: PlainFields
            where FieldOwner == ClassId
            using PlainInitAssignmentContributions

        apply plain_properties
            from field: PlainFields
            where FieldOwner == ClassId
            using PlainPropertyContributions
    }

    assembly LifecycleCoreModule = CoreModuleProduction

}
