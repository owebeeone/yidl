module tests.lifecycle_owned

import "lifecycle_transient.yidl" as transient

export concept LifecycleOwned

concept LifecycleOwned extends transient.LifecycleTransient {

    family transient.LifecycleFieldSpec {
        variant BindingField {
        }

        variant OwnedField {
        }
    }

    computed collection BindingFields: LifecycleFieldSpec from Fields where FieldKind == "binding"
    computed collection OwnedFields: LifecycleFieldSpec from Fields where FieldKind == "owned"
    computed collection BindingScalarFields:
        LifecycleFieldSpec from Fields where FieldKind == "binding" and BindingShape == "scalar"
    computed collection BindingMapFields:
        LifecycleFieldSpec from Fields where FieldKind == "binding" and BindingShape == "map"
    computed collection OwnedScalarFields:
        LifecycleFieldSpec from Fields where FieldKind == "owned" and BindingShape == "scalar"
    computed collection OwnedMapFields:
        LifecycleFieldSpec from Fields where FieldKind == "owned" and BindingShape == "map"

    record IndexedOwnedField {
        FieldId
        FieldOwner
        FieldName
        FieldOrder
        BindingShape
        TxGroupKey
        TxIndex
        CurrentSlotName
        WorkingSlotName
        StagedSlotName
    }

    collection IndexedOwnedFields: IndexedOwnedField identity FieldId many

    resource BuildOwnedFactsBody = code $[
        from yidl.runtime.transaction_yidl import DEFAULT_TRANSACTION

        tx_groups = {
            (tx_group.tx_owner, tx_group.tx_group_key): tx_group.tx_index
            for tx_group in ctx.records(TxGroupsCollection)
        }
        for field in ctx.records(FieldsCollection):
            if field.field_kind != "owned":
                continue
            tx_group = field.tx_group_key
            if tx_group is None:
                tx_group = DEFAULT_TRANSACTION
            ctx.write(
                IndexedOwnedFieldsCollection,
                IndexedOwnedField(
                    field_id=field.field_id,
                    field_owner=field.field_owner,
                    field_name=field.field_name,
                    field_order=field.field_order,
                    binding_shape=field.binding_shape,
                    tx_group_key=tx_group,
                    tx_index=tx_groups[(field.field_owner, tx_group)],
                    current_slot_name=field.current_slot_name,
                    working_slot_name=field.working_slot_name,
                    staged_slot_name=field.staged_slot_name,
                ),
                policy=RejectDuplicate,
            )
    ]$ {
        keep ctx, FieldsCollection, TxGroupsCollection
        keep IndexedOwnedFieldsCollection, IndexedOwnedField
        keep RejectDuplicate
    }

    operation BuildOwnedFacts
        inputs(Fields, TxGroups)
        outputs(IndexedOwnedFields)
        using BuildOwnedFactsBody

    resource BindingSupportHelper = code $[
        def _y_validate_binding_value(field_name, value):
            from yidl.runtime.bindings import BindingBase

            if value is not None and not isinstance(value, BindingBase):
                raise TypeError(
                    "binding field " + repr(field_name)
                    + " expects BindingBase or None"
                )
            return value

        def _y_validate_binding_map_value(field_name, value):
            from collections.abc import Mapping

            from yidl.runtime.bindings import BindingBase
            from yidl.runtime.bindings import BindingDict

            if value is None:
                return None
            if not isinstance(value, Mapping):
                raise TypeError(
                    "binding map field " + repr(field_name)
                    + " expects a mapping or None"
                )
            result = value if isinstance(value, BindingDict) else BindingDict(value)
            for key, item in result.items():
                if not isinstance(item, BindingBase):
                    raise TypeError(
                        "binding map field " + repr(field_name)
                        + " expects BindingBase values; key "
                        + repr(key)
                        + " has "
                        + type(item).__name__
                    )
            return result
    ]$

    resource OwnedScalarStateAssignment = template $[
        value = astichi_pass(init_value_name__astichi_arg__, outer_bind=True)
        astichi_pass(state, outer_bind=True).astichi_ref(external=state_slot)._ = (
            _y_validate_binding_value(astichi_bind_external(field_name), value)
        )
    ]$

    resource OwnedMapStateAssignment = template $[
        value = astichi_pass(init_value_name__astichi_arg__, outer_bind=True)
        astichi_pass(state, outer_bind=True).astichi_ref(external=state_slot)._ = (
            _y_validate_binding_map_value(astichi_bind_external(field_name), value)
        )
    ]$

    resource OwnedEmptyStateAssignment = template $[
        astichi_pass(state, outer_bind=True).astichi_ref(external=state_slot)._ = VOID
    ]$ {
        keep VOID
    }

    resource OwnedDefaultProperty = template $[
        @property
        def property_getter_name__astichi_arg__(self):
            state = self._y_state
            if state.astichi_ref(external=working_slot) is not VOID:
                return state.astichi_ref(external=working_slot)
            return state.astichi_ref(external=current_slot)

        @property_setter_target_name__astichi_arg__.setter
        def property_setter_name__astichi_arg__(self, value):
            state = self._y_state
            state._y_ensure_working_transaction(astichi_bind_external(tx_index))
            state.astichi_ref(external=working_slot)._ = (
                _y_validate_binding_value(astichi_bind_external(field_name), value)
            )
    ]$ {
        keep VOID
    }

    resource OwnedMapDefaultProperty = template $[
        @property
        def property_getter_name__astichi_arg__(self):
            state = self._y_state
            if state.astichi_ref(external=working_slot) is not VOID:
                return state.astichi_ref(external=working_slot)
            return state.astichi_ref(external=current_slot)

        @property_setter_target_name__astichi_arg__.setter
        def property_setter_name__astichi_arg__(self, value):
            state = self._y_state
            state._y_ensure_working_transaction(astichi_bind_external(tx_index))
            state.astichi_ref(external=working_slot)._ = (
                _y_validate_binding_map_value(astichi_bind_external(field_name), value)
            )
    ]$ {
        keep VOID
    }

    resource OwnedCurrentProperty = template $[
        @property
        def property_getter_name__astichi_arg__(self):
            return self._y_state.astichi_ref(external=current_slot)

        @property_setter_target_name__astichi_arg__.setter
        def property_setter_name__astichi_arg__(self, value):
            del value
            raise AttributeError(
                "current facade is read-only for owned field "
                + astichi_bind_external(field_name)
            )
    ]$

    resource OwnedWorkingProperty = template $[
        @property
        def property_getter_name__astichi_arg__(self):
            state = self._y_state
            if state.astichi_ref(external=working_slot) is not VOID:
                return state.astichi_ref(external=working_slot)
            return state.astichi_ref(external=current_slot)

        @property_setter_target_name__astichi_arg__.setter
        def property_setter_name__astichi_arg__(self, value):
            state = self._y_state
            state._y_ensure_working_transaction(astichi_bind_external(tx_index))
            state.astichi_ref(external=working_slot)._ = (
                _y_validate_binding_value(astichi_bind_external(field_name), value)
            )
    ]$ {
        keep VOID
    }

    resource OwnedMapWorkingProperty = template $[
        @property
        def property_getter_name__astichi_arg__(self):
            state = self._y_state
            if state.astichi_ref(external=working_slot) is not VOID:
                return state.astichi_ref(external=working_slot)
            return state.astichi_ref(external=current_slot)

        @property_setter_target_name__astichi_arg__.setter
        def property_setter_name__astichi_arg__(self, value):
            state = self._y_state
            state._y_ensure_working_transaction(astichi_bind_external(tx_index))
            state.astichi_ref(external=working_slot)._ = (
                _y_validate_binding_map_value(astichi_bind_external(field_name), value)
            )
    ]$ {
        keep VOID
    }

    resource OwnedPrepareCommitBranch = template $[
        if astichi_pass(self, outer_bind=True).astichi_ref(external=working_slot) is not VOID:
            value = astichi_pass(self, outer_bind=True).astichi_ref(external=working_slot)
            if value is not None:
                value.accepted()
            astichi_pass(self, outer_bind=True).astichi_ref(external=staged_slot)._ = value
    ]$ {
        keep VOID
    }

    resource OwnedMapPrepareCommitBranch = template $[
        if astichi_pass(self, outer_bind=True).astichi_ref(external=working_slot) is not VOID:
            value = astichi_pass(self, outer_bind=True).astichi_ref(external=working_slot)
            if value is not None:
                for item in value.values():
                    item.accepted()
            astichi_pass(self, outer_bind=True).astichi_ref(external=staged_slot)._ = value
    ]$ {
        keep VOID
    }

    resource OwnedScalarDefaultFactoryEvalInit = template $[
        if astichi_pass(field_name__astichi_arg__, outer_bind=True) is _HAS_DEFAULT_FACTORY:
            astichi_pass(field_name__astichi_arg__, outer_bind=True)._ = (
                default_factory_name__astichi_arg__(
                    **astichi_hole(default_factory_args)
                )
            )
        value = astichi_pass(field_name__astichi_arg__, outer_bind=True)
        from yidl.runtime.bindings import BindingBase
        if value is not None and not isinstance(value, BindingBase):
            raise TypeError(
                "binding field " + repr(astichi_bind_external(field_name_value))
                + " expects BindingBase or None"
            )
        astichi_pass(state, outer_bind=True).astichi_ref(external=state_slot)._ = value
    ]$ {
        keep _HAS_DEFAULT_FACTORY
    }

    resource OwnedScalarDefaultFactoryEvalNoInit = template $[
        field_name__astichi_arg__ = default_factory_name__astichi_arg__(
            **astichi_hole(default_factory_args)
        )
        value = astichi_pass(field_name__astichi_arg__, outer_bind=True)
        from yidl.runtime.bindings import BindingBase
        if value is not None and not isinstance(value, BindingBase):
            raise TypeError(
                "binding field " + repr(astichi_bind_external(field_name_value))
                + " expects BindingBase or None"
            )
        astichi_pass(state, outer_bind=True).astichi_ref(external=state_slot)._ = value
    ]$

    resource OwnedMapDefaultFactoryEvalInit = template $[
        if astichi_pass(field_name__astichi_arg__, outer_bind=True) is _HAS_DEFAULT_FACTORY:
            astichi_pass(field_name__astichi_arg__, outer_bind=True)._ = (
                default_factory_name__astichi_arg__(
                    **astichi_hole(default_factory_args)
                )
            )
        value = astichi_pass(field_name__astichi_arg__, outer_bind=True)
        from collections.abc import Mapping
        from yidl.runtime.bindings import BindingBase
        from yidl.runtime.bindings import BindingDict
        if value is not None and not isinstance(value, Mapping):
            raise TypeError(
                "binding map field " + repr(astichi_bind_external(field_name_value))
                + " expects a mapping or None"
            )
        if value is not None:
            value = value if isinstance(value, BindingDict) else BindingDict(value)
            for key, item in value.items():
                if not isinstance(item, BindingBase):
                    raise TypeError(
                        "binding map field "
                        + repr(astichi_bind_external(field_name_value))
                        + " expects BindingBase values; key "
                        + repr(key)
                        + " has "
                        + type(item).__name__
                    )
        astichi_pass(state, outer_bind=True).astichi_ref(external=state_slot)._ = value
    ]$ {
        keep _HAS_DEFAULT_FACTORY
    }

    resource OwnedMapDefaultFactoryEvalNoInit = template $[
        field_name__astichi_arg__ = default_factory_name__astichi_arg__(
            **astichi_hole(default_factory_args)
        )
        value = astichi_pass(field_name__astichi_arg__, outer_bind=True)
        from collections.abc import Mapping
        from yidl.runtime.bindings import BindingBase
        from yidl.runtime.bindings import BindingDict
        if value is not None and not isinstance(value, Mapping):
            raise TypeError(
                "binding map field " + repr(astichi_bind_external(field_name_value))
                + " expects a mapping or None"
            )
        if value is not None:
            value = value if isinstance(value, BindingDict) else BindingDict(value)
            for key, item in value.items():
                if not isinstance(item, BindingBase):
                    raise TypeError(
                        "binding map field "
                        + repr(astichi_bind_external(field_name_value))
                        + " expects BindingBase values; key "
                        + repr(key)
                        + " has "
                        + type(item).__name__
                    )
        astichi_pass(state, outer_bind=True).astichi_ref(external=state_slot)._ = value
    ]$

    resource OwnedApplyPreparedCommitBranch = template $[
        if astichi_pass(self, outer_bind=True).astichi_ref(external=staged_slot) is not VOID:
            astichi_pass(self, outer_bind=True).astichi_ref(external=current_slot)._ = (
                astichi_pass(self, outer_bind=True).astichi_ref(external=staged_slot)
            )
            astichi_pass(self, outer_bind=True).astichi_ref(external=staged_slot)._ = VOID
            astichi_pass(self, outer_bind=True).astichi_ref(external=working_slot)._ = VOID
    ]$ {
        keep VOID
    }

    resource OwnedRollbackBranch = template $[
        astichi_pass(self, outer_bind=True).astichi_ref(external=staged_slot)._ = VOID
        astichi_pass(self, outer_bind=True).astichi_ref(external=working_slot)._ = VOID
    ]$ {
        keep VOID
    }

    resource BindingStateAssignment = template $[
        astichi_pass(state, outer_bind=True).astichi_ref(external=state_slot)._ = (
            _y_validate_binding_value(
                astichi_bind_external(field_name),
                astichi_pass(init_value_name__astichi_arg__, outer_bind=True),
            )
        )
    ]$

    resource BindingMapStateAssignment = template $[
        astichi_pass(state, outer_bind=True).astichi_ref(external=state_slot)._ = (
            _y_validate_binding_map_value(
                astichi_bind_external(field_name),
                astichi_pass(init_value_name__astichi_arg__, outer_bind=True),
            )
        )
    ]$

    resource BindingProperty = template $[
        @property
        def property_getter_name__astichi_arg__(self):
            return self._y_state.astichi_ref(external=state_slot)

        @property_setter_target_name__astichi_arg__.setter
        def property_setter_name__astichi_arg__(self, value):
            self._y_state.astichi_ref(external=state_slot)._ = (
                _y_validate_binding_value(astichi_bind_external(field_name), value)
            )
    ]$

    resource BindingMapProperty = template $[
        @property
        def property_getter_name__astichi_arg__(self):
            return self._y_state.astichi_ref(external=state_slot)

        @property_setter_target_name__astichi_arg__.setter
        def property_setter_name__astichi_arg__(self, value):
            self._y_state.astichi_ref(external=state_slot)._ = (
                _y_validate_binding_map_value(astichi_bind_external(field_name), value)
            )
    ]$

    resource BindingDefaultFactoryEvalInit = template $[
        if astichi_pass(field_name__astichi_arg__, outer_bind=True) is _HAS_DEFAULT_FACTORY:
            astichi_pass(field_name__astichi_arg__, outer_bind=True)._ = (
                default_factory_name__astichi_arg__(
                    **astichi_hole(default_factory_args)
                )
            )
        astichi_pass(self, outer_bind=True).astichi_ref(external=property_name)._ = astichi_pass(
            field_name__astichi_arg__,
            outer_bind=True,
        )
    ]$ {
        keep _HAS_DEFAULT_FACTORY
    }

    resource BindingDefaultFactoryEvalNoInit = template $[
        field_name__astichi_arg__ = default_factory_name__astichi_arg__(
            **astichi_hole(default_factory_args)
        )
        astichi_pass(self, outer_bind=True).astichi_ref(external=property_name)._ = astichi_pass(
            field_name__astichi_arg__,
            outer_bind=True,
        )
    ]$

    contribution BindingSupportHelperContribution = BindingSupportHelper {
        as BindingSupportHelper
        index ClassOrder
        order -1000

        target function_body {
            build /Root
        }
    }

    contribution BindingStateSlot = StateSlotEntry {
        as BindingStateSlot
        index FieldOrder
        order FieldOrder

        target state_slots {
            build /ClassDef
        }

        external slot_name = ValueSlotName
    }

    contribution OwnedCurrentStateSlot = StateSlotEntry {
        as OwnedCurrentStateSlot
        index FieldOrder
        order FieldOrder

        target state_slots {
            build /ClassDef
        }

        external slot_name = CurrentSlotName
    }

    contribution OwnedWorkingStateSlot = StateSlotEntry {
        as OwnedWorkingStateSlot
        index FieldOrder
        order FieldOrder

        target state_slots {
            build /ClassDef
        }

        external slot_name = WorkingSlotName
    }

    contribution OwnedStagedStateSlot = StateSlotEntry {
        as OwnedStagedStateSlot
        index FieldOrder
        order FieldOrder

        target state_slots {
            build /ClassDef
        }

        external slot_name = StagedSlotName
    }

    contribution BindingInitParamRequired = InitParamRequired {
        as BindingInitParam
        index FieldOrder
        order FieldOrder

        target init_params {
            build /ClassDef
        }

        ident param_name = FieldName
        external annotation = Annotation
    }

    contribution BindingInitParamDefault = InitParamDefault {
        as BindingInitParam
        index FieldOrder
        order FieldOrder

        target init_params {
            build /ClassDef
        }

        ident param_name = FieldName
        external annotation = Annotation
        ident default_value_name = DefaultValueParamName
    }

    contribution BindingInitParamDefaultFactory = InitParamDefaultFactory {
        as BindingInitParam
        index FieldOrder
        order FieldOrder

        target init_params {
            build /ClassDef
        }

        ident param_name = FieldName
        external annotation = Annotation
    }

    contribution OwnedInitParamRequired = InitParamRequired {
        as OwnedInitParam
        index FieldOrder
        order FieldOrder

        target init_params {
            build /ClassDef
        }

        ident param_name = FieldName
        external annotation = Annotation
    }

    contribution OwnedInitParamDefault = InitParamDefault {
        as OwnedInitParam
        index FieldOrder
        order FieldOrder

        target init_params {
            build /ClassDef
        }

        ident param_name = FieldName
        external annotation = Annotation
        ident default_value_name = DefaultValueParamName
    }

    contribution OwnedInitParamDefaultFactory = InitParamDefaultFactory {
        as OwnedInitParam
        index FieldOrder
        order FieldOrder

        target init_params {
            build /ClassDef
        }

        ident param_name = FieldName
        external annotation = Annotation
    }

    contribution BindingInitAssignment = BindingStateAssignment {
        as BindingInitAssignment
        index FieldOrder
        order FieldOrder

        target state_init_body {
            build /ClassDef
        }

        ident init_value_name = FieldName
        external field_name = FieldName
        external state_slot = ValueSlotName
    }

    contribution BindingDefaultAssignment = BindingStateAssignment {
        as BindingInitAssignment
        index FieldOrder
        order FieldOrder

        target state_init_body {
            build /ClassDef
        }

        ident init_value_name = DefaultValueParamName
        external field_name = FieldName
        external state_slot = ValueSlotName
    }

    contribution BindingMapInitAssignment = BindingMapStateAssignment {
        as BindingInitAssignment
        index FieldOrder
        order FieldOrder

        target state_init_body {
            build /ClassDef
        }

        ident init_value_name = FieldName
        external field_name = FieldName
        external state_slot = ValueSlotName
    }

    contribution BindingMapDefaultAssignment = BindingMapStateAssignment {
        as BindingInitAssignment
        index FieldOrder
        order FieldOrder

        target state_init_body {
            build /ClassDef
        }

        ident init_value_name = DefaultValueParamName
        external field_name = FieldName
        external state_slot = ValueSlotName
    }

    contribution BindingFieldProperty = BindingProperty {
        as BindingFieldProperty
        index FieldOrder
        order FieldOrder

        target facade_properties {
            build /ClassDef
        }

        ident property_getter_name = FieldName
        ident property_setter_target_name = FieldName
        ident property_setter_name = FieldName
        external field_name = FieldName
        external state_slot = ValueSlotName
    }

    contribution BindingMapFieldProperty = BindingMapProperty {
        as BindingFieldProperty
        index FieldOrder
        order FieldOrder

        target facade_properties {
            build /ClassDef
        }

        ident property_getter_name = FieldName
        ident property_setter_target_name = FieldName
        ident property_setter_name = FieldName
        external field_name = FieldName
        external state_slot = ValueSlotName
    }

    contribution OwnedCurrentInitAssignment = OwnedScalarStateAssignment {
        as OwnedCurrentInitAssignment
        index FieldOrder
        order FieldOrder

        target state_init_body {
            build /ClassDef
        }

        ident init_value_name = FieldName
        external field_name = FieldName
        external state_slot = CurrentSlotName
    }

    contribution OwnedCurrentDefaultAssignment = OwnedScalarStateAssignment {
        as OwnedCurrentInitAssignment
        index FieldOrder
        order FieldOrder

        target state_init_body {
            build /ClassDef
        }

        ident init_value_name = DefaultValueParamName
        external field_name = FieldName
        external state_slot = CurrentSlotName
    }

    contribution OwnedMapCurrentInitAssignment = OwnedMapStateAssignment {
        as OwnedCurrentInitAssignment
        index FieldOrder
        order FieldOrder

        target state_init_body {
            build /ClassDef
        }

        ident init_value_name = FieldName
        external field_name = FieldName
        external state_slot = CurrentSlotName
    }

    contribution OwnedMapCurrentDefaultAssignment = OwnedMapStateAssignment {
        as OwnedCurrentInitAssignment
        index FieldOrder
        order FieldOrder

        target state_init_body {
            build /ClassDef
        }

        ident init_value_name = DefaultValueParamName
        external field_name = FieldName
        external state_slot = CurrentSlotName
    }

    contribution OwnedWorkingInitAssignment = OwnedEmptyStateAssignment {
        as OwnedWorkingInitAssignment
        index FieldOrder
        order FieldOrder

        target state_init_body {
            build /ClassDef
        }

        external state_slot = WorkingSlotName
    }

    contribution OwnedStagedInitAssignment = OwnedEmptyStateAssignment {
        as OwnedStagedInitAssignment
        index FieldOrder
        order FieldOrder

        target state_init_body {
            build /ClassDef
        }

        external state_slot = StagedSlotName
    }

    contribution OwnedDefaultFacadeProperty = OwnedDefaultProperty {
        as OwnedDefaultFacadeProperty
        index FieldOrder
        order FieldOrder

        target default_facade_properties {
            build /ClassDef
        }

        ident property_getter_name = FieldName
        ident property_setter_target_name = FieldName
        ident property_setter_name = FieldName
        external current_slot = CurrentSlotName
        external working_slot = WorkingSlotName
        external field_name = FieldName
        external tx_index = TxIndex
    }

    contribution OwnedMapDefaultFacadeProperty = OwnedMapDefaultProperty {
        as OwnedDefaultFacadeProperty
        index FieldOrder
        order FieldOrder

        target default_facade_properties {
            build /ClassDef
        }

        ident property_getter_name = FieldName
        ident property_setter_target_name = FieldName
        ident property_setter_name = FieldName
        external current_slot = CurrentSlotName
        external working_slot = WorkingSlotName
        external field_name = FieldName
        external tx_index = TxIndex
    }

    contribution OwnedCurrentFacadeProperty = OwnedCurrentProperty {
        as OwnedCurrentFacadeProperty
        index FieldOrder
        order FieldOrder

        target current_facade_properties {
            build /ClassDef
        }

        ident property_getter_name = FieldName
        ident property_setter_target_name = FieldName
        ident property_setter_name = FieldName
        external current_slot = CurrentSlotName
        external field_name = FieldName
    }

    contribution OwnedWorkingFacadeProperty = OwnedWorkingProperty {
        as OwnedWorkingFacadeProperty
        index FieldOrder
        order FieldOrder

        target working_facade_properties {
            build /ClassDef
        }

        ident property_getter_name = FieldName
        ident property_setter_target_name = FieldName
        ident property_setter_name = FieldName
        external current_slot = CurrentSlotName
        external working_slot = WorkingSlotName
        external field_name = FieldName
        external tx_index = TxIndex
    }

    contribution OwnedMapWorkingFacadeProperty = OwnedMapWorkingProperty {
        as OwnedWorkingFacadeProperty
        index FieldOrder
        order FieldOrder

        target working_facade_properties {
            build /ClassDef
        }

        ident property_getter_name = FieldName
        ident property_setter_target_name = FieldName
        ident property_setter_name = FieldName
        external current_slot = CurrentSlotName
        external working_slot = WorkingSlotName
        external field_name = FieldName
        external tx_index = TxIndex
    }

    contribution OwnedPrepareCommit = OwnedPrepareCommitBranch {
        as OwnedPrepareCommit
        index FieldOrder
        order FieldOrder

        target prepare_commit_fields_body {
            build /ClassDef/PrepareCommitFields[TxIndex]
        }

        external working_slot = WorkingSlotName
        external staged_slot = StagedSlotName
    }

    contribution OwnedMapPrepareCommit = OwnedMapPrepareCommitBranch {
        as OwnedPrepareCommit
        index FieldOrder
        order FieldOrder

        target prepare_commit_fields_body {
            build /ClassDef/PrepareCommitFields[TxIndex]
        }

        external working_slot = WorkingSlotName
        external staged_slot = StagedSlotName
    }

    contribution OwnedApplyPreparedCommit = OwnedApplyPreparedCommitBranch {
        as OwnedApplyPreparedCommit
        index FieldOrder
        order FieldOrder

        target apply_prepared_commit_fields_body {
            build /ClassDef/ApplyPreparedCommitFields[TxIndex]
        }

        external current_slot = CurrentSlotName
        external working_slot = WorkingSlotName
        external staged_slot = StagedSlotName
    }

    contribution OwnedRollback = OwnedRollbackBranch {
        as OwnedRollback
        index FieldOrder
        order FieldOrder

        target rollback_fields_body {
            build /ClassDef/RollbackFields[TxIndex]
        }

        external working_slot = WorkingSlotName
        external staged_slot = StagedSlotName
    }

    contribution OwnedScalarDefaultFactoryEvalInitContribution = OwnedScalarDefaultFactoryEvalInit {
        as DefaultFactoryEval
        index EvalOrder
        order EvalStatementOrder

        target state_init_body {
            build /ClassDef
        }

        ident field_name = EvalFieldName
        ident default_factory_name = EvalDefaultFactoryParamName
        external field_name_value = EvalFieldName
        external state_slot = EvalStateSlotName
    }

    contribution OwnedScalarDefaultFactoryEvalNoInitContribution = OwnedScalarDefaultFactoryEvalNoInit {
        as DefaultFactoryEval
        index EvalOrder
        order EvalStatementOrder

        target state_init_body {
            build /ClassDef
        }

        ident field_name = EvalFieldName
        ident default_factory_name = EvalDefaultFactoryParamName
        external field_name_value = EvalFieldName
        external state_slot = EvalStateSlotName
    }

    contribution OwnedMapDefaultFactoryEvalInitContribution = OwnedMapDefaultFactoryEvalInit {
        as DefaultFactoryEval
        index EvalOrder
        order EvalStatementOrder

        target state_init_body {
            build /ClassDef
        }

        ident field_name = EvalFieldName
        ident default_factory_name = EvalDefaultFactoryParamName
        external field_name_value = EvalFieldName
        external state_slot = EvalStateSlotName
    }

    contribution OwnedMapDefaultFactoryEvalNoInitContribution = OwnedMapDefaultFactoryEvalNoInit {
        as DefaultFactoryEval
        index EvalOrder
        order EvalStatementOrder

        target state_init_body {
            build /ClassDef
        }

        ident field_name = EvalFieldName
        ident default_factory_name = EvalDefaultFactoryParamName
        external field_name_value = EvalFieldName
        external state_slot = EvalStateSlotName
    }

    contribution BindingDefaultFactoryEvalInitContribution = BindingDefaultFactoryEvalInit {
        as DefaultFactoryEval
        index EvalOrder
        order EvalStatementOrder

        target state_init_body {
            build /ClassDef
        }

        ident field_name = EvalFieldName
        ident default_factory_name = EvalDefaultFactoryParamName
        external property_name = EvalFieldName
    }

    contribution BindingDefaultFactoryEvalNoInitContribution = BindingDefaultFactoryEvalNoInit {
        as DefaultFactoryEval
        index EvalOrder
        order EvalStatementOrder

        target state_init_body {
            build /ClassDef
        }

        ident field_name = EvalFieldName
        ident default_factory_name = EvalDefaultFactoryParamName
        external property_name = EvalFieldName
    }

    matcher BindingSupportHelperContributions(lifecycle_class: Classes) -> contribution {
        default -> BindingSupportHelperContribution
    }

    matcher BindingStateSlotContributions(field: BindingFields) -> contribution {
        default -> BindingStateSlot
    }

    matcher OwnedCurrentStateSlotContributions(field: OwnedFields) -> contribution {
        default -> OwnedCurrentStateSlot
    }

    matcher OwnedWorkingStateSlotContributions(field: OwnedFields) -> contribution {
        default -> OwnedWorkingStateSlot
    }

    matcher OwnedStagedStateSlotContributions(field: OwnedFields) -> contribution {
        default -> OwnedStagedStateSlot
    }

    matcher BindingInitParamContributions(field: BindingFields) -> contribution {
        rule required when Init == True
                      and HasDefault == False
                      and HasDefaultFactory == False
                      -> BindingInitParamRequired
        rule default_value when Init == True
                           and HasDefault == True
                           and HasDefaultFactory == False
                           -> BindingInitParamDefault
        rule default_factory when Init == True
                             and HasDefaultFactory == True
                             -> BindingInitParamDefaultFactory
    }

    matcher OwnedInitParamContributions(field: OwnedFields) -> contribution {
        rule required when Init == True
                      and HasDefault == False
                      and HasDefaultFactory == False
                      -> OwnedInitParamRequired
        rule default_value when Init == True
                           and HasDefault == True
                           and HasDefaultFactory == False
                           -> OwnedInitParamDefault
        rule default_factory when Init == True
                             and HasDefaultFactory == True
                             -> OwnedInitParamDefaultFactory
    }

    matcher BindingInitAssignmentContributions(field: BindingFields) -> contribution {
        rule init_field when Init == True
                        and BindingShape == "scalar"
                        and HasDefaultFactory == False
                        -> BindingInitAssignment
        rule default_value when Init == False
                           and BindingShape == "scalar"
                           and HasDefault == True
                           and HasDefaultFactory == False
                           -> BindingDefaultAssignment
        rule map_init_field when Init == True
                            and BindingShape == "map"
                            and HasDefaultFactory == False
                            -> BindingMapInitAssignment
        rule map_default_value when Init == False
                               and BindingShape == "map"
                               and HasDefault == True
                               and HasDefaultFactory == False
                               -> BindingMapDefaultAssignment
    }

    matcher BindingPropertyContributions(field: BindingFields) -> contribution {
        default -> BindingFieldProperty
        rule map_field when BindingShape == "map" -> BindingMapFieldProperty
    }

    matcher OwnedCurrentInitAssignmentContributions(field: OwnedFields) -> contribution {
        rule init_field when Init == True
                        and BindingShape == "scalar"
                        and HasDefaultFactory == False
                        -> OwnedCurrentInitAssignment
        rule default_value when Init == False
                           and BindingShape == "scalar"
                           and HasDefault == True
                           and HasDefaultFactory == False
                           -> OwnedCurrentDefaultAssignment
        rule map_init_field when Init == True
                            and BindingShape == "map"
                            and HasDefaultFactory == False
                            -> OwnedMapCurrentInitAssignment
        rule map_default_value when Init == False
                               and BindingShape == "map"
                               and HasDefault == True
                               and HasDefaultFactory == False
                               -> OwnedMapCurrentDefaultAssignment
    }

    matcher OwnedWorkingInitAssignmentContributions(field: OwnedFields) -> contribution {
        default -> OwnedWorkingInitAssignment
    }

    matcher OwnedStagedInitAssignmentContributions(field: OwnedFields) -> contribution {
        default -> OwnedStagedInitAssignment
    }

    matcher OwnedDefaultFacadePropertyContributions(field: IndexedOwnedFields) -> contribution {
        default -> OwnedDefaultFacadeProperty
        rule map_field when BindingShape == "map" -> OwnedMapDefaultFacadeProperty
    }

    matcher OwnedCurrentFacadePropertyContributions(field: IndexedOwnedFields) -> contribution {
        default -> OwnedCurrentFacadeProperty
    }

    matcher OwnedWorkingFacadePropertyContributions(field: IndexedOwnedFields) -> contribution {
        default -> OwnedWorkingFacadeProperty
        rule map_field when BindingShape == "map" -> OwnedMapWorkingFacadeProperty
    }

    matcher OwnedPrepareCommitContributions(field: IndexedOwnedFields) -> contribution {
        default -> OwnedPrepareCommit
        rule map_field when BindingShape == "map" -> OwnedMapPrepareCommit
    }

    matcher OwnedApplyPreparedCommitContributions(field: IndexedOwnedFields) -> contribution {
        default -> OwnedApplyPreparedCommit
    }

    matcher OwnedRollbackContributions(field: IndexedOwnedFields) -> contribution {
        default -> OwnedRollback
    }

    matcher DefaultFactoryEvalContributions(step: DefaultFactoryEvaluationSteps) -> contribution {
        rule binding_init when EvalFieldKind == "binding"
                          and EvalInit == True
                          -> BindingDefaultFactoryEvalInitContribution
        rule binding_no_init when EvalFieldKind == "binding"
                             and EvalInit == False
                             -> BindingDefaultFactoryEvalNoInitContribution
        rule owned_scalar_init when EvalFieldKind == "owned"
                               and EvalBindingShape == "scalar"
                               and EvalInit == True
                               -> OwnedScalarDefaultFactoryEvalInitContribution
        rule owned_scalar_no_init when EvalFieldKind == "owned"
                                  and EvalBindingShape == "scalar"
                                  and EvalInit == False
                                  -> OwnedScalarDefaultFactoryEvalNoInitContribution
        rule owned_map_init when EvalFieldKind == "owned"
                            and EvalBindingShape == "map"
                            and EvalInit == True
                            -> OwnedMapDefaultFactoryEvalInitContribution
        rule owned_map_no_init when EvalFieldKind == "owned"
                               and EvalBindingShape == "map"
                               and EvalInit == False
                               -> OwnedMapDefaultFactoryEvalNoInitContribution
    }
}
