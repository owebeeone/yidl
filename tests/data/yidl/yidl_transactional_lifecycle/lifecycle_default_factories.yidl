module tests.lifecycle_default_factories

import "lifecycle_managed.yidl" as managed

export concept LifecycleDefaultFactories

concept LifecycleDefaultFactories extends managed.LifecycleManaged {

    # -------------------------------------------------------------------------
    # Default-factory dependency facts.
    # -------------------------------------------------------------------------

    property DependencyOwner: str
    property ConsumerFieldId: str
    property ConsumerFieldName: str = ""
    property ProviderName: str
    property ProviderFieldId: str = ""
    property ProviderFieldKind: str = ""
    property ProviderInit: bool = True  # Provider availability columns are informational now and reserved for future matchers.
    property ProviderHasDefault: bool = False
    property ProviderHasDefaultFactory: bool = False
    property ParamName: str
    property ParamOrder: int = 0
    property ConsumerEvalOrder: int = 0

    property EvalStepId: str
    property EvalOwner: str
    property EvalFieldId: str
    property EvalFieldName: str
    property EvalFieldKind: str = ""
    property EvalInit: bool = True
    property EvalStateSlotName: str = ""
    property EvalDefaultFactoryParamName: str = ""
    property EvalOrder: int = 0
    property EvalStatementOrder: int = 0  # Factory eval statements add 100000 so normal field initialization stays first; revisit if generated field counts approach that offset.

    property DiagnosticId: str
    property DiagnosticOwner: str
    property DiagnosticFieldId: str = ""
    property DiagnosticMessage: str

    record DefaultFactoryDependency {
        DependencyOwner
        ConsumerFieldId
        ConsumerFieldName
        ProviderName
        ProviderFieldId
        ProviderFieldKind
        ProviderInit
        ProviderHasDefault
        ProviderHasDefaultFactory
        ParamName
        ParamOrder
        ConsumerEvalOrder
    }

    record DefaultFactoryEvaluationStep {
        EvalStepId
        EvalOwner
        EvalFieldId
        EvalFieldName
        EvalFieldKind
        EvalInit
        EvalStateSlotName
        EvalDefaultFactoryParamName
        EvalOrder
        EvalStatementOrder
    }

    record DefaultFactoryDiagnostic {
        DiagnosticId
        DiagnosticOwner
        DiagnosticFieldId
        DiagnosticMessage
    }

    collection DefaultFactoryDependencies:
        DefaultFactoryDependency identity (ConsumerFieldId, ParamName) many
    collection DefaultFactoryEvaluationSteps:
        DefaultFactoryEvaluationStep identity EvalStepId many
    collection DefaultFactoryDiagnostics:
        DefaultFactoryDiagnostic identity DiagnosticId many

    resource BuildDefaultFactoryFactsBody = code $[
        classes = sorted(
            ctx.records(ClassesCollection),
            key=lambda item: item.class_order,
        )
        fields = sorted(
            ctx.records(FieldsCollection),
            key=lambda item: item.field_order,
        )

        for lifecycle_class in classes:
            class_fields = [
                field for field in fields
                if field.field_owner == lifecycle_class.class_id
            ]
            by_name = {field.field_name: field for field in class_fields}
            by_id = {field.field_id: field for field in class_fields}
            factory_fields = [
                field for field in class_fields
                if field.has_default_factory
            ]
            graph = {field.field_id: set() for field in factory_fields}
            deps = []
            diagnostic_count = 0

            def add_diagnostic(field, suffix, message):
                nonlocal diagnostic_count
                diagnostic_count += 1
                ctx.write(
                    DefaultFactoryDiagnosticsCollection,
                    DefaultFactoryDiagnostic(
                        diagnostic_id=(
                            f"{field.field_id}.{suffix}.{diagnostic_count}"
                        ),
                        diagnostic_owner=lifecycle_class.class_id,
                        diagnostic_field_id=field.field_id,
                        diagnostic_message=message,
                    ),
                    policy=ReplaceExisting,
                )

            def provider_is_available(provider):
                if provider.init:
                    return True
                return provider.has_default or provider.has_default_factory

            for consumer in factory_fields:
                for param_order, param_name in enumerate(
                    consumer.default_factory_param_names
                ):
                    provider = by_name.get(param_name)
                    if provider is None:
                        add_diagnostic(
                            consumer,
                            f"unknown.{param_name}",
                            (
                                f"{lifecycle_class.class_name}."
                                f"{consumer.field_name}: default_factory "
                                f"references unknown name {param_name!r}"
                            ),
                        )
                        continue
                    if not provider_is_available(provider):
                        add_diagnostic(
                            consumer,
                            f"unavailable.{param_name}",
                            (
                                f"{lifecycle_class.class_name}."
                                f"{consumer.field_name}: default_factory "
                                f"cannot reference {param_name!r} "
                                "(value is unavailable before factory evaluation)"
                            ),
                        )
                        continue
                    deps.append((consumer, provider, param_name, param_order))
                    if provider.field_id in graph:
                        graph[consumer.field_id].add(provider.field_id)

            field_order = {
                field.field_id: field.field_order for field in class_fields
            }
            visiting = set()
            visited = set()
            ordered_field_ids = []
            cycle_found = False

            def visit(field_id, path):
                nonlocal cycle_found
                if cycle_found or field_id in visited:
                    return
                if field_id in visiting:
                    cycle = path[path.index(field_id):]
                    names = " -> ".join(by_id[item].field_name for item in cycle)
                    add_diagnostic(
                        by_id[field_id],
                        "cycle",
                        (
                            f"{lifecycle_class.class_name}: default_factory "
                            f"dependency cycle: {names}"
                        ),
                    )
                    cycle_found = True
                    return
                visiting.add(field_id)
                for provider_id in sorted(
                    graph.get(field_id, ()),
                    key=lambda item: field_order[item],
                ):
                    visit(provider_id, [*path, provider_id])
                visiting.remove(field_id)
                visited.add(field_id)
                ordered_field_ids.append(field_id)

            for field in factory_fields:
                visit(field.field_id, [field.field_id])
                if cycle_found:
                    break

            if diagnostic_count:
                continue

            eval_order_by_id = {
                field_id: eval_order
                for eval_order, field_id in enumerate(ordered_field_ids)
            }

            for consumer, provider, param_name, param_order in deps:
                ctx.write(
                    DefaultFactoryDependenciesCollection,
                    DefaultFactoryDependency(
                        dependency_owner=lifecycle_class.class_id,
                        consumer_field_id=consumer.field_id,
                        consumer_field_name=consumer.field_name,
                        provider_name=provider.field_name,
                        provider_field_id=provider.field_id,
                        provider_field_kind=provider.field_kind,
                        provider_init=provider.init,
                        provider_has_default=provider.has_default,
                        provider_has_default_factory=provider.has_default_factory,
                        param_name=param_name,
                        param_order=param_order,
                        consumer_eval_order=eval_order_by_id[consumer.field_id],
                    ),
                    policy=RejectDuplicate,
                )

            for field in factory_fields:
                if field.default_factory_param_names:
                    continue
                ctx.write(
                    DefaultFactoryDependenciesCollection,
                    DefaultFactoryDependency(
                        dependency_owner=lifecycle_class.class_id,
                        consumer_field_id=field.field_id,
                        consumer_field_name=field.field_name,
                        provider_name="",
                        provider_field_id="",
                        provider_field_kind="",
                        provider_init=True,
                        provider_has_default=False,
                        provider_has_default_factory=False,
                        param_name="",
                        param_order=-1,
                        consumer_eval_order=eval_order_by_id[field.field_id],
                    ),
                    policy=RejectDuplicate,
                )

            for eval_order, field_id in enumerate(ordered_field_ids):
                field = by_id[field_id]
                state_slot = ""
                if field.field_kind == "field":
                    state_slot = field.value_slot_name
                elif field.field_kind == "binding":
                    state_slot = field.value_slot_name
                elif field.field_kind == "managed":
                    state_slot = field.current_slot_name
                elif field.field_kind == "transient":
                    state_slot = field.current_slot_name
                ctx.write(
                    DefaultFactoryEvaluationStepsCollection,
                    DefaultFactoryEvaluationStep(
                        eval_step_id=field.field_id,
                        eval_owner=lifecycle_class.class_id,
                        eval_field_id=field.field_id,
                        eval_field_name=field.field_name,
                        eval_field_kind=field.field_kind,
                        eval_init=field.init,
                        eval_state_slot_name=state_slot,
                        eval_default_factory_param_name=(
                            field.default_factory_param_name
                        ),
                        eval_order=eval_order,
                        eval_statement_order=100000 + eval_order,
                    ),
                    policy=RejectDuplicate,
                )
    ]$ {
        keep ctx, ClassesCollection, FieldsCollection
        keep DefaultFactoryDependenciesCollection
        keep DefaultFactoryEvaluationStepsCollection
        keep DefaultFactoryDiagnosticsCollection
        keep DefaultFactoryDependency, DefaultFactoryEvaluationStep
        keep DefaultFactoryDiagnostic, RejectDuplicate, ReplaceExisting
    }

    operation BuildDefaultFactoryFacts
        inputs(Classes, Fields)
        outputs(DefaultFactoryDependencies, DefaultFactoryEvaluationSteps, DefaultFactoryDiagnostics)
        using BuildDefaultFactoryFactsBody

    resource RaiseDefaultFactoryDiagnosticsBody = code $[
        for diagnostic in ctx.records(DefaultFactoryDiagnosticsCollection):
            raise AssemblyDiagnosticError(diagnostic.diagnostic_message)
    ]$ {
        keep ctx, DefaultFactoryDiagnosticsCollection, AssemblyDiagnosticError
    }

    operation RaiseDefaultFactoryDiagnostics
        inputs(DefaultFactoryDiagnostics)
        outputs()
        using RaiseDefaultFactoryDiagnosticsBody

    # -------------------------------------------------------------------------
    # Default-factory resources.
    # -------------------------------------------------------------------------

    resource InitParamDefaultFactory = template $[
        def astichi_params(
            param_name__astichi_arg__: astichi_bind_external(annotation)
            = _HAS_DEFAULT_FACTORY
        ):
            pass
    ]$ {
        keep _HAS_DEFAULT_FACTORY
    }

    resource StoredDefaultFactoryEvalInit = template $[
        if astichi_pass(field_name__astichi_arg__, outer_bind=True) is _HAS_DEFAULT_FACTORY:
            astichi_pass(field_name__astichi_arg__, outer_bind=True)._ = (
                default_factory_name__astichi_arg__(
                    **astichi_hole(default_factory_args)
                )
            )
        astichi_pass(state, outer_bind=True).astichi_ref(external=state_slot)._ = astichi_pass(
            field_name__astichi_arg__,
            outer_bind=True,
        )
    ]$ {
        keep _HAS_DEFAULT_FACTORY
    }

    resource StoredDefaultFactoryEvalNoInit = template $[
        field_name__astichi_arg__ = default_factory_name__astichi_arg__(
            **astichi_hole(default_factory_args)
        )
        astichi_pass(state, outer_bind=True).astichi_ref(external=state_slot)._ = astichi_pass(
            field_name__astichi_arg__,
            outer_bind=True,
        )
    ]$

    resource InitVarDefaultFactoryEvalInit = template $[
        if astichi_pass(field_name__astichi_arg__, outer_bind=True) is _HAS_DEFAULT_FACTORY:
            astichi_pass(field_name__astichi_arg__, outer_bind=True)._ = (
                default_factory_name__astichi_arg__(
                    **astichi_hole(default_factory_args)
                )
            )
    ]$ {
        keep _HAS_DEFAULT_FACTORY
    }

    resource InitVarDefaultFactoryEvalNoInit = template $[
        field_name__astichi_arg__ = default_factory_name__astichi_arg__(
            **astichi_hole(default_factory_args)
        )
    ]$

    resource DefaultFactoryStoredArg = template $[
        astichi_funcargs(
            param_name__astichi_arg__=astichi_pass(
                self,
                outer_bind=True,
            ).astichi_ref(external=provider_name)
        )
    ]$

    resource DefaultFactoryLocalArg = template $[
        astichi_funcargs(
            param_name__astichi_arg__=astichi_pass(
                provider_name__astichi_arg__,
                outer_bind=True,
            )
        )
    ]$

    resource DefaultFactoryEmptyArg = template $[
        astichi_funcargs()
    ]$

    contribution FieldDefaultFactoryBuilderParam = BuilderParam {
        as FieldDefaultFactoryBuilderParam
        index FieldOrder
        order FieldOrder

        target builder_params {
            build /Root
        }

        ident value_name = DefaultFactoryParamName
    }

    contribution PlainInitParamDefaultFactory = InitParamDefaultFactory {
        as PlainInitParam
        index FieldOrder
        order FieldOrder

        target init_params {
            build /ClassDef
        }

        ident param_name = FieldName
        external annotation = Annotation
    }

    contribution InitVarParamDefaultFactory = InitParamDefaultFactory {
        as InitVarParam
        index FieldOrder
        order FieldOrder

        target init_params {
            build /ClassDef
        }

        ident param_name = FieldName
        external annotation = Annotation
    }

    contribution ManagedInitParamDefaultFactory = InitParamDefaultFactory {
        as ManagedInitParam
        index FieldOrder
        order FieldOrder

        target init_params {
            build /ClassDef
        }

        ident param_name = FieldName
        external annotation = Annotation
    }

    contribution StoredDefaultFactoryEvalInitContribution = StoredDefaultFactoryEvalInit {
        as DefaultFactoryEval
        index EvalOrder
        order EvalStatementOrder

        target state_init_body {
            build /ClassDef
        }

        ident field_name = EvalFieldName
        ident default_factory_name = EvalDefaultFactoryParamName
        external state_slot = EvalStateSlotName
    }

    contribution StoredDefaultFactoryEvalNoInitContribution = StoredDefaultFactoryEvalNoInit {
        as DefaultFactoryEval
        index EvalOrder
        order EvalStatementOrder

        target state_init_body {
            build /ClassDef
        }

        ident field_name = EvalFieldName
        ident default_factory_name = EvalDefaultFactoryParamName
        external state_slot = EvalStateSlotName
    }

    contribution InitVarDefaultFactoryEvalInitContribution = InitVarDefaultFactoryEvalInit {
        as DefaultFactoryEval
        index EvalOrder
        order EvalStatementOrder

        target state_init_body {
            build /ClassDef
        }

        ident field_name = EvalFieldName
        ident default_factory_name = EvalDefaultFactoryParamName
    }

    contribution InitVarDefaultFactoryEvalNoInitContribution = InitVarDefaultFactoryEvalNoInit {
        as DefaultFactoryEval
        index EvalOrder
        order EvalStatementOrder

        target state_init_body {
            build /ClassDef
        }

        ident field_name = EvalFieldName
        ident default_factory_name = EvalDefaultFactoryParamName
    }

    contribution DefaultFactoryStoredArgContribution = DefaultFactoryStoredArg {
        as DefaultFactoryArg
        index (ConsumerEvalOrder, ParamOrder)
        order ParamOrder

        target default_factory_args {
            build /ClassDef/DefaultFactoryEval[ConsumerEvalOrder]
        }

        ident param_name = ParamName
        external provider_name = ProviderName
    }

    contribution DefaultFactoryLocalArgContribution = DefaultFactoryLocalArg {
        as DefaultFactoryArg
        index (ConsumerEvalOrder, ParamOrder)
        order ParamOrder

        target default_factory_args {
            build /ClassDef/DefaultFactoryEval[ConsumerEvalOrder]
        }

        ident param_name = ParamName
        ident provider_name = ProviderName
    }

    contribution DefaultFactoryEmptyArgContribution = DefaultFactoryEmptyArg {
        as DefaultFactoryArg
        index (ConsumerEvalOrder, ParamOrder)
        order ParamOrder

        target default_factory_args {
            build /ClassDef/DefaultFactoryEval[ConsumerEvalOrder]
        }
    }

    matcher FieldDefaultBuilderParamContributions(field: Fields) -> contribution {
        rule has_default_factory when HasDefaultFactory == True -> FieldDefaultFactoryBuilderParam
    }

    matcher PlainInitParamContributions(field: PlainFields) -> contribution {
        rule default_factory when Init == True
                             and HasDefaultFactory == True
                             -> PlainInitParamDefaultFactory
    }

    matcher InitVarParamContributions(field: InitVarFields) -> contribution {
        rule default_factory when Init == True
                             and HasDefaultFactory == True
                             -> InitVarParamDefaultFactory
    }

    matcher ManagedInitParamContributions(field: ManagedFields) -> contribution {
        rule default_factory when Init == True
                             and HasDefaultFactory == True
                             -> ManagedInitParamDefaultFactory
    }

    matcher DefaultFactoryEvalContributions(step: DefaultFactoryEvaluationSteps) -> contribution {
        rule field_init when EvalFieldKind == "field"
                        and EvalInit == True
                        -> StoredDefaultFactoryEvalInitContribution
        rule field_no_init when EvalFieldKind == "field"
                           and EvalInit == False
                           -> StoredDefaultFactoryEvalNoInitContribution
        rule managed_init when EvalFieldKind == "managed"
                          and EvalInit == True
                          -> StoredDefaultFactoryEvalInitContribution
        rule managed_no_init when EvalFieldKind == "managed"
                             and EvalInit == False
                             -> StoredDefaultFactoryEvalNoInitContribution
        rule initvar_init when EvalFieldKind == "initvar"
                          and EvalInit == True
                          -> InitVarDefaultFactoryEvalInitContribution
        rule initvar_no_init when EvalFieldKind == "initvar"
                             and EvalInit == False
                             -> InitVarDefaultFactoryEvalNoInitContribution
    }

    matcher DefaultFactoryArgContributions(dep: DefaultFactoryDependencies) -> contribution {
        default -> DefaultFactoryStoredArgContribution
        rule empty_provider when ParamName == "" -> DefaultFactoryEmptyArgContribution
        rule local_provider when ProviderFieldKind == "initvar"
                            -> DefaultFactoryLocalArgContribution
    }

}
