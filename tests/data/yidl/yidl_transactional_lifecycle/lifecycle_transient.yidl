module tests.lifecycle_transient

import "lifecycle_default_factories.yidl" as default_factories

export concept LifecycleTransient

concept LifecycleTransient extends default_factories.LifecycleDefaultFactories {

    family default_factories.LifecycleFieldSpec {
        variant TransientField {
        }
    }

    computed collection TransientFields: LifecycleFieldSpec from Fields where FieldKind == "transient"

    record IndexedTransientField {
        FieldId
        FieldOwner
        FieldName
        FieldOrder
        TxGroupKey
        TxIndex
        CurrentSlotName
        WorkingSlotName
        HasWorkingDefaultFactory
        WorkingDefaultFactoryParamName
    }

    collection IndexedTransientFields: IndexedTransientField identity FieldId many

    property RetainedSlotName: str = ""
    property RetainOrder: int = 0
    property WorkingFactoryArgId: str
    property WorkingFactoryArgOwner: str
    property WorkingFactoryConsumerFieldId: str
    property WorkingFactoryConsumerFieldOrder: int = 0
    property WorkingFactoryArgKind: str = ""

    record RetainedInitVar {
        FieldId
        FieldOwner
        FieldName
        FieldOrder
        RetainedSlotName
        RetainOrder
    }

    record TransientWorkingFactoryArg {
        WorkingFactoryArgId
        WorkingFactoryArgOwner
        WorkingFactoryConsumerFieldId
        WorkingFactoryConsumerFieldOrder
        ParamName
        ParamOrder
        ProviderName
        WorkingFactoryArgKind
        RetainedSlotName
    }

    collection RetainedInitVars: RetainedInitVar identity FieldId many
    collection TransientWorkingFactoryArgs:
        TransientWorkingFactoryArg identity WorkingFactoryArgId many

    resource BuildTransientFactsBody = code $[
        from yidl.runtime.transaction_yidl import DEFAULT_TRANSACTION

        fields = list(ctx.records(FieldsCollection))
        by_owner_name = {
            (field.field_owner, field.field_name): field
            for field in fields
        }
        tx_groups = {
            (tx_group.tx_owner, tx_group.tx_group_key): tx_group.tx_index
            for tx_group in ctx.records(TxGroupsCollection)
        }
        for field in fields:
            if field.field_kind != "transient":
                continue
            tx_group = field.tx_group_key
            if tx_group is None:
                tx_group = DEFAULT_TRANSACTION
            tx_index = tx_groups[(field.field_owner, tx_group)]
            ctx.write(
                IndexedTransientFieldsCollection,
                IndexedTransientField(
                    field_id=field.field_id,
                    field_owner=field.field_owner,
                    field_name=field.field_name,
                    field_order=field.field_order,
                    tx_group_key=tx_group,
                    tx_index=tx_index,
                    current_slot_name=field.current_slot_name,
                    working_slot_name=field.working_slot_name,
                    has_working_default_factory=field.has_working_default_factory,
                    working_default_factory_param_name=(
                        field.working_default_factory_param_name
                    ),
                ),
                policy=RejectDuplicate,
            )
            if (
                field.has_working_default_factory
                and not field.working_default_factory_param_names
            ):
                ctx.write(
                    TransientWorkingFactoryArgsCollection,
                    TransientWorkingFactoryArg(
                        working_factory_arg_id=f"{field.field_id}.__empty__",
                        working_factory_arg_owner=field.field_owner,
                        working_factory_consumer_field_id=field.field_id,
                        working_factory_consumer_field_order=field.field_order,
                        param_name="",
                        param_order=-1,
                        provider_name="",
                        working_factory_arg_kind="empty",
                        retained_slot_name="",
                    ),
                    policy=RejectDuplicate,
                )
            for param_order, param_name in enumerate(
                field.working_default_factory_param_names
            ):
                arg_kind = ""
                provider_name = param_name
                retained_slot_name = ""
                if param_name in {"self", "current", "working"}:
                    arg_kind = param_name
                else:
                    provider = by_owner_name.get((field.field_owner, param_name))
                    if provider is None:
                        raise AssemblyDiagnosticError(
                            f"{field.field_name}: working_default_factory "
                            f"references unknown name {param_name!r}"
                        )
                    if provider.field_kind != "initvar":
                        raise AssemblyDiagnosticError(
                            f"{field.field_name}: working_default_factory "
                            f"cannot retain non-initvar provider {param_name!r}"
                        )
                    if (
                        not provider.init
                        and not provider.has_default
                        and not provider.has_default_factory
                    ):
                        raise AssemblyDiagnosticError(
                            f"{field.field_name}: working_default_factory "
                            f"cannot retain initvar {param_name!r} without "
                            "a default or default_factory"
                        )
                    arg_kind = "retained_initvar"
                    retained_slot_name = f"_y_{param_name}_initvar"
                    ctx.write(
                        RetainedInitVarsCollection,
                        RetainedInitVar(
                            field_id=provider.field_id,
                            field_owner=provider.field_owner,
                            field_name=provider.field_name,
                            field_order=provider.field_order,
                            retained_slot_name=retained_slot_name,
                            retain_order=200000 + provider.field_order,
                        ),
                        policy=ReplaceExisting,
                    )
                ctx.write(
                    TransientWorkingFactoryArgsCollection,
                    TransientWorkingFactoryArg(
                        working_factory_arg_id=f"{field.field_id}.{param_name}",
                        working_factory_arg_owner=field.field_owner,
                        working_factory_consumer_field_id=field.field_id,
                        working_factory_consumer_field_order=field.field_order,
                        param_name=param_name,
                        param_order=param_order,
                        provider_name=provider_name,
                        working_factory_arg_kind=arg_kind,
                        retained_slot_name=retained_slot_name,
                    ),
                    policy=RejectDuplicate,
                )
    ]$ {
        keep ctx, FieldsCollection, TxGroupsCollection
        keep IndexedTransientFieldsCollection, IndexedTransientField
        keep RetainedInitVarsCollection, RetainedInitVar
        keep TransientWorkingFactoryArgsCollection, TransientWorkingFactoryArg
        keep RejectDuplicate, ReplaceExisting, AssemblyDiagnosticError
    }

    operation BuildTransientFacts
        inputs(Fields, TxGroups)
        outputs(IndexedTransientFields, RetainedInitVars, TransientWorkingFactoryArgs)
        using BuildTransientFactsBody

    resource TransientCurrentProperty = template $[
        @property
        def property_getter_name__astichi_arg__(self):
            return self._y_state.astichi_ref(external=current_slot)
    ]$

    resource TransientWorkingStateAssignment = template $[
        astichi_pass(state, outer_bind=True).astichi_ref(external=working_slot)._ = VOID
    ]$ {
        keep VOID
    }

    resource TransientFacadeProperty = template $[
        @property
        def property_getter_name__astichi_arg__(self):
            state = self._y_state
            if state.astichi_ref(external=working_slot) is not VOID:
                return state.astichi_ref(external=working_slot)
            tx_key = state.__yidl_tx_index_to_key__[astichi_bind_external(tx_index)]
            if state._y_transaction_manager.active_transaction_for(tx_key) is None:
                return state.astichi_ref(external=current_slot)
            state._y_ensure_working_transaction(astichi_bind_external(tx_index))
            state.astichi_ref(external=working_slot)._ = (
                state.astichi_ref(external=current_slot)
            )
            return state.astichi_ref(external=working_slot)

        @property_setter_target_name__astichi_arg__.setter
        def property_setter_name__astichi_arg__(self, value):
            state = self._y_state
            state._y_ensure_working_transaction(astichi_bind_external(tx_index))
            state.astichi_ref(external=working_slot)._ = value
    ]$ {
        keep VOID
    }

    resource TransientWorkingDefaultFactoryProperty = template $[
        @property
        def property_getter_name__astichi_arg__(self):
            state = self._y_state
            if state.astichi_ref(external=working_slot) is not VOID:
                return state.astichi_ref(external=working_slot)
            tx_key = state.__yidl_tx_index_to_key__[astichi_bind_external(tx_index)]
            if state._y_transaction_manager.active_transaction_for(tx_key) is None:
                return state.astichi_ref(external=current_slot)
            state._y_ensure_working_transaction(astichi_bind_external(tx_index))
            state.astichi_ref(external=working_slot)._ = (
                working_default_factory_name__astichi_arg__(
                    **astichi_hole(working_default_factory_args)
                )
            )
            return state.astichi_ref(external=working_slot)

        @property_setter_target_name__astichi_arg__.setter
        def property_setter_name__astichi_arg__(self, value):
            state = self._y_state
            state._y_ensure_working_transaction(astichi_bind_external(tx_index))
            state.astichi_ref(external=working_slot)._ = value
    ]$ {
        keep VOID
    }

    resource TransientClearWorkingBranch = template $[
        astichi_pass(self, outer_bind=True).astichi_ref(external=working_slot)._ = VOID
    ]$ {
        keep VOID
    }

    resource RetainedInitVarAssignment = template $[
        astichi_pass(state, outer_bind=True).astichi_ref(external=retained_slot)._ = astichi_pass(
            init_value_name__astichi_arg__,
            outer_bind=True,
        )
    ]$

    resource TransientWorkingFactorySelfArg = template $[
        astichi_funcargs(
            param_name__astichi_arg__=astichi_pass(
                state,
                outer_bind=True,
            )._y_get_default_facade()
        )
    ]$

    resource TransientWorkingFactoryCurrentArg = template $[
        astichi_funcargs(
            param_name__astichi_arg__=astichi_pass(
                state,
                outer_bind=True,
            )._y_get_current_facade()
        )
    ]$

    resource TransientWorkingFactoryWorkingArg = template $[
        astichi_funcargs(
            param_name__astichi_arg__=astichi_pass(
                state,
                outer_bind=True,
            )._y_get_working_facade()
        )
    ]$

    resource TransientWorkingFactoryRetainedInitVarArg = template $[
        astichi_funcargs(
            param_name__astichi_arg__=astichi_pass(
                state,
                outer_bind=True,
            ).astichi_ref(external=retained_slot)
        )
    ]$

    resource TransientWorkingFactoryEmptyArg = template $[
        astichi_funcargs()
    ]$

    contribution TransientCurrentStateSlot = StateSlotEntry {
        as TransientCurrentStateSlot
        index FieldOrder
        order FieldOrder

        target state_slots {
            build /ClassDef
        }

        external slot_name = CurrentSlotName
    }

    contribution TransientWorkingStateSlot = StateSlotEntry {
        as TransientWorkingStateSlot
        index FieldOrder
        order FieldOrder

        target state_slots {
            build /ClassDef
        }

        external slot_name = WorkingSlotName
    }

    contribution RetainedInitVarStateSlot = StateSlotEntry {
        as RetainedInitVarStateSlot
        index FieldOrder
        order FieldOrder

        target state_slots {
            build /ClassDef
        }

        external slot_name = RetainedSlotName
    }

    contribution TransientWorkingDefaultFactoryBuilderParam = BuilderParam {
        as TransientWorkingDefaultFactoryBuilderParam
        index FieldOrder
        order FieldOrder

        target builder_params {
            build /Root
        }

        ident value_name = WorkingDefaultFactoryParamName
    }

    contribution TransientInitParamRequired = InitParamRequired {
        as TransientInitParam
        index FieldOrder
        order FieldOrder

        target init_params {
            build /ClassDef
        }

        ident param_name = FieldName
        external annotation = Annotation
    }

    contribution TransientInitParamDefault = InitParamDefault {
        as TransientInitParam
        index FieldOrder
        order FieldOrder

        target init_params {
            build /ClassDef
        }

        ident param_name = FieldName
        external annotation = Annotation
        ident default_value_name = DefaultValueParamName
    }

    contribution TransientInitParamDefaultFactory = InitParamDefaultFactory {
        as TransientInitParam
        index FieldOrder
        order FieldOrder

        target init_params {
            build /ClassDef
        }

        ident param_name = FieldName
        external annotation = Annotation
    }

    contribution TransientCurrentInitAssignment = PlainStateAssignment {
        as TransientCurrentInitAssignment
        index FieldOrder
        order FieldOrder

        target state_init_body {
            build /ClassDef
        }

        ident init_value_name = FieldName
        external state_slot = CurrentSlotName
    }

    contribution TransientCurrentDefaultAssignment = PlainStateAssignment {
        as TransientCurrentDefaultAssignment
        index FieldOrder
        order FieldOrder

        target state_init_body {
            build /ClassDef
        }

        ident init_value_name = DefaultValueParamName
        external state_slot = CurrentSlotName
    }

    contribution TransientWorkingInitAssignment = TransientWorkingStateAssignment {
        as TransientWorkingInitAssignment
        index FieldOrder
        order FieldOrder

        target state_init_body {
            build /ClassDef
        }

        external working_slot = WorkingSlotName
    }

    contribution RetainedInitVarStateAssignment = RetainedInitVarAssignment {
        as RetainedInitVarStateAssignment
        index FieldOrder
        order RetainOrder

        target state_init_body {
            build /ClassDef
        }

        ident init_value_name = FieldName
        external retained_slot = RetainedSlotName
    }

    contribution TransientCurrentPropertyContribution = TransientCurrentProperty {
        as TransientCurrentProperty
        index FieldOrder
        order FieldOrder

        target current_facade_properties {
            build /ClassDef
        }

        ident property_getter_name = FieldName
        external current_slot = CurrentSlotName
    }

    contribution TransientDefaultFacadeProperty = TransientFacadeProperty {
        as TransientDefaultFacadeProperty
        index FieldOrder
        order FieldOrder

        target default_facade_properties {
            build /ClassDef
        }

        ident property_getter_name = FieldName
        ident property_setter_target_name = FieldName
        ident property_setter_name = FieldName
        external current_slot = CurrentSlotName
        external working_slot = WorkingSlotName
        external tx_index = TxIndex
    }

    contribution TransientDefaultWorkingDefaultFactoryProperty = TransientWorkingDefaultFactoryProperty {
        as TransientDefaultFacadeProperty
        index FieldOrder
        order FieldOrder

        target default_facade_properties {
            build /ClassDef
        }

        ident property_getter_name = FieldName
        ident property_setter_target_name = FieldName
        ident property_setter_name = FieldName
        ident working_default_factory_name = WorkingDefaultFactoryParamName
        external current_slot = CurrentSlotName
        external working_slot = WorkingSlotName
        external tx_index = TxIndex
    }

    contribution TransientWorkingFacadeProperty = TransientFacadeProperty {
        as TransientWorkingFacadeProperty
        index FieldOrder
        order FieldOrder

        target working_facade_properties {
            build /ClassDef
        }

        ident property_getter_name = FieldName
        ident property_setter_target_name = FieldName
        ident property_setter_name = FieldName
        external current_slot = CurrentSlotName
        external working_slot = WorkingSlotName
        external tx_index = TxIndex
    }

    contribution TransientWorkingWorkingDefaultFactoryProperty = TransientWorkingDefaultFactoryProperty {
        as TransientWorkingFacadeProperty
        index FieldOrder
        order FieldOrder

        target working_facade_properties {
            build /ClassDef
        }

        ident property_getter_name = FieldName
        ident property_setter_target_name = FieldName
        ident property_setter_name = FieldName
        ident working_default_factory_name = WorkingDefaultFactoryParamName
        external current_slot = CurrentSlotName
        external working_slot = WorkingSlotName
        external tx_index = TxIndex
    }

    contribution TransientDefaultWorkingFactorySelfArg = TransientWorkingFactorySelfArg {
        as TransientDefaultWorkingFactoryArg
        index (WorkingFactoryConsumerFieldOrder, ParamOrder)
        order ParamOrder

        target working_default_factory_args {
            build /ClassDef/TransientDefaultFacadeProperty[WorkingFactoryConsumerFieldOrder]
        }

        ident param_name = ParamName
    }

    contribution TransientDefaultWorkingFactoryCurrentArg = TransientWorkingFactoryCurrentArg {
        as TransientDefaultWorkingFactoryArg
        index (WorkingFactoryConsumerFieldOrder, ParamOrder)
        order ParamOrder

        target working_default_factory_args {
            build /ClassDef/TransientDefaultFacadeProperty[WorkingFactoryConsumerFieldOrder]
        }

        ident param_name = ParamName
    }

    contribution TransientDefaultWorkingFactoryWorkingArg = TransientWorkingFactoryWorkingArg {
        as TransientDefaultWorkingFactoryArg
        index (WorkingFactoryConsumerFieldOrder, ParamOrder)
        order ParamOrder

        target working_default_factory_args {
            build /ClassDef/TransientDefaultFacadeProperty[WorkingFactoryConsumerFieldOrder]
        }

        ident param_name = ParamName
    }

    contribution TransientDefaultWorkingFactoryRetainedInitVarArg = TransientWorkingFactoryRetainedInitVarArg {
        as TransientDefaultWorkingFactoryArg
        index (WorkingFactoryConsumerFieldOrder, ParamOrder)
        order ParamOrder

        target working_default_factory_args {
            build /ClassDef/TransientDefaultFacadeProperty[WorkingFactoryConsumerFieldOrder]
        }

        ident param_name = ParamName
        external retained_slot = RetainedSlotName
    }

    contribution TransientDefaultWorkingFactoryEmptyArg = TransientWorkingFactoryEmptyArg {
        as TransientDefaultWorkingFactoryArg
        index (WorkingFactoryConsumerFieldOrder, ParamOrder)
        order ParamOrder

        target working_default_factory_args {
            build /ClassDef/TransientDefaultFacadeProperty[WorkingFactoryConsumerFieldOrder]
        }
    }

    contribution TransientWorkingWorkingFactorySelfArg = TransientWorkingFactorySelfArg {
        as TransientWorkingWorkingFactoryArg
        index (WorkingFactoryConsumerFieldOrder, ParamOrder)
        order ParamOrder

        target working_default_factory_args {
            build /ClassDef/TransientWorkingFacadeProperty[WorkingFactoryConsumerFieldOrder]
        }

        ident param_name = ParamName
    }

    contribution TransientWorkingWorkingFactoryCurrentArg = TransientWorkingFactoryCurrentArg {
        as TransientWorkingWorkingFactoryArg
        index (WorkingFactoryConsumerFieldOrder, ParamOrder)
        order ParamOrder

        target working_default_factory_args {
            build /ClassDef/TransientWorkingFacadeProperty[WorkingFactoryConsumerFieldOrder]
        }

        ident param_name = ParamName
    }

    contribution TransientWorkingWorkingFactoryWorkingArg = TransientWorkingFactoryWorkingArg {
        as TransientWorkingWorkingFactoryArg
        index (WorkingFactoryConsumerFieldOrder, ParamOrder)
        order ParamOrder

        target working_default_factory_args {
            build /ClassDef/TransientWorkingFacadeProperty[WorkingFactoryConsumerFieldOrder]
        }

        ident param_name = ParamName
    }

    contribution TransientWorkingWorkingFactoryRetainedInitVarArg = TransientWorkingFactoryRetainedInitVarArg {
        as TransientWorkingWorkingFactoryArg
        index (WorkingFactoryConsumerFieldOrder, ParamOrder)
        order ParamOrder

        target working_default_factory_args {
            build /ClassDef/TransientWorkingFacadeProperty[WorkingFactoryConsumerFieldOrder]
        }

        ident param_name = ParamName
        external retained_slot = RetainedSlotName
    }

    contribution TransientWorkingWorkingFactoryEmptyArg = TransientWorkingFactoryEmptyArg {
        as TransientWorkingWorkingFactoryArg
        index (WorkingFactoryConsumerFieldOrder, ParamOrder)
        order ParamOrder

        target working_default_factory_args {
            build /ClassDef/TransientWorkingFacadeProperty[WorkingFactoryConsumerFieldOrder]
        }
    }

    contribution TransientApplyPreparedCommit = TransientClearWorkingBranch {
        as TransientApplyPreparedCommit
        index FieldOrder
        order FieldOrder

        target apply_prepared_commit_fields_body {
            build /ClassDef/ApplyPreparedCommitFields[TxIndex]
        }

        external working_slot = WorkingSlotName
    }

    contribution TransientRollback = TransientClearWorkingBranch {
        as TransientRollback
        index FieldOrder
        order FieldOrder

        target rollback_fields_body {
            build /ClassDef/RollbackFields[TxIndex]
        }

        external working_slot = WorkingSlotName
    }

    matcher TransientCurrentStateSlotContributions(field: TransientFields) -> contribution {
        default -> TransientCurrentStateSlot
    }

    matcher TransientWorkingStateSlotContributions(field: TransientFields) -> contribution {
        default -> TransientWorkingStateSlot
    }

    matcher RetainedInitVarStateSlotContributions(initvar: RetainedInitVars) -> contribution {
        default -> RetainedInitVarStateSlot
    }

    matcher TransientWorkingDefaultBuilderParamContributions(field: Fields) -> contribution {
        rule has_working_default_factory when HasWorkingDefaultFactory == True
                                         -> TransientWorkingDefaultFactoryBuilderParam
    }

    matcher TransientInitParamContributions(field: TransientFields) -> contribution {
        rule required when Init == True
                      and HasDefault == False
                      and HasDefaultFactory == False
                      -> TransientInitParamRequired
        rule default_value when Init == True
                            and HasDefault == True
                            and HasDefaultFactory == False
                            -> TransientInitParamDefault
        rule default_factory when Init == True
                             and HasDefaultFactory == True
                             -> TransientInitParamDefaultFactory
    }

    matcher TransientCurrentInitAssignmentContributions(field: TransientFields) -> contribution {
        rule init_value when Init == True
                        and HasDefaultFactory == False
                        -> TransientCurrentInitAssignment
        rule default_value when Init == False
                           and HasDefault == True
                           and HasDefaultFactory == False
                           -> TransientCurrentDefaultAssignment
    }

    matcher TransientWorkingInitAssignmentContributions(field: TransientFields) -> contribution {
        default -> TransientWorkingInitAssignment
    }

    matcher RetainedInitVarStateAssignmentContributions(initvar: RetainedInitVars) -> contribution {
        default -> RetainedInitVarStateAssignment
    }

    matcher TransientCurrentPropertyContributions(field: TransientFields) -> contribution {
        default -> TransientCurrentPropertyContribution
    }

    matcher TransientDefaultFacadePropertyContributions(field: IndexedTransientFields) -> contribution {
        default -> TransientDefaultFacadeProperty
        rule working_default_factory when HasWorkingDefaultFactory == True
                                     -> TransientDefaultWorkingDefaultFactoryProperty
    }

    matcher TransientWorkingFacadePropertyContributions(field: IndexedTransientFields) -> contribution {
        default -> TransientWorkingFacadeProperty
        rule working_default_factory when HasWorkingDefaultFactory == True
                                     -> TransientWorkingWorkingDefaultFactoryProperty
    }

    matcher TransientApplyPreparedCommitContributions(field: IndexedTransientFields) -> contribution {
        default -> TransientApplyPreparedCommit
    }

    matcher TransientRollbackContributions(field: IndexedTransientFields) -> contribution {
        default -> TransientRollback
    }

    matcher TransientDefaultWorkingFactoryArgContributions(arg: TransientWorkingFactoryArgs) -> contribution {
        rule empty when WorkingFactoryArgKind == "empty"
                   -> TransientDefaultWorkingFactoryEmptyArg
        rule self_arg when WorkingFactoryArgKind == "self"
                      -> TransientDefaultWorkingFactorySelfArg
        rule current_arg when WorkingFactoryArgKind == "current"
                         -> TransientDefaultWorkingFactoryCurrentArg
        rule working_arg when WorkingFactoryArgKind == "working"
                         -> TransientDefaultWorkingFactoryWorkingArg
        rule retained_initvar when WorkingFactoryArgKind == "retained_initvar"
                              -> TransientDefaultWorkingFactoryRetainedInitVarArg
    }

    matcher TransientWorkingWorkingFactoryArgContributions(arg: TransientWorkingFactoryArgs) -> contribution {
        rule empty when WorkingFactoryArgKind == "empty"
                   -> TransientWorkingWorkingFactoryEmptyArg
        rule self_arg when WorkingFactoryArgKind == "self"
                      -> TransientWorkingWorkingFactorySelfArg
        rule current_arg when WorkingFactoryArgKind == "current"
                         -> TransientWorkingWorkingFactoryCurrentArg
        rule working_arg when WorkingFactoryArgKind == "working"
                         -> TransientWorkingWorkingFactoryWorkingArg
        rule retained_initvar when WorkingFactoryArgKind == "retained_initvar"
                              -> TransientWorkingWorkingFactoryRetainedInitVarArg
    }

    matcher DefaultFactoryEvalContributions(step: DefaultFactoryEvaluationSteps) -> contribution {
        rule transient_init when EvalFieldKind == "transient"
                            and EvalInit == True
                            -> StoredDefaultFactoryEvalInitContribution
        rule transient_no_init when EvalFieldKind == "transient"
                               and EvalInit == False
                               -> StoredDefaultFactoryEvalNoInitContribution
    }

    extend production CoreModuleProduction {
        phase transient_working_default_params after field_default_params order 10
            from field: Fields {
            apply transient_working_default_params using TransientWorkingDefaultBuilderParamContributions
        }
    }

    extend production CoreClassProduction {
        phase state_slots_transient_current after state_slots_plain order 60
            from field: TransientFields
            where FieldOwner == ClassId {
            apply transient_current_state_slots using TransientCurrentStateSlotContributions
        }

        phase state_slots_transient_working after state_slots_plain order 80
            from field: TransientFields
            where FieldOwner == ClassId {
            apply transient_working_state_slots using TransientWorkingStateSlotContributions
        }

        phase state_slots_retained_initvar after state_slots_plain order 90
            from initvar: RetainedInitVars
            where FieldOwner == ClassId {
            apply retained_initvar_state_slots using RetainedInitVarStateSlotContributions
        }

        phase init_params_transient after init_params_initvar order 20
            from field: TransientFields
            where FieldOwner == ClassId {
            apply transient_init_params using TransientInitParamContributions
        }

        phase init_assignments_transient_current after init_assignments_plain order 40
            from field: TransientFields
            where FieldOwner == ClassId {
            apply transient_current_init_assignments using TransientCurrentInitAssignmentContributions
        }

        phase init_assignments_transient_working after init_assignments_plain order 60
            from field: TransientFields
            where FieldOwner == ClassId {
            apply transient_working_init_assignments using TransientWorkingInitAssignmentContributions
        }

        phase init_assignments_retained_initvar after init_assignments_plain order 80
            from initvar: RetainedInitVars
            where FieldOwner == ClassId {
            apply retained_initvar_state_assignments using RetainedInitVarStateAssignmentContributions
        }

        phase properties_transient_default after properties_plain order 40
            from field: IndexedTransientFields
            where FieldOwner == ClassId {
            apply transient_default_properties using TransientDefaultFacadePropertyContributions
        }

        phase properties_transient_current after properties_plain order 60
            from field: TransientFields
            where FieldOwner == ClassId {
            apply transient_current_properties using TransientCurrentPropertyContributions
        }

        phase properties_transient_working after properties_plain order 100
            from field: IndexedTransientFields
            where FieldOwner == ClassId {
            apply transient_working_properties using TransientWorkingFacadePropertyContributions
        }

        phase transient_default_working_factory_args after properties_plain order 110
            from arg: TransientWorkingFactoryArgs
            where WorkingFactoryArgOwner == ClassId {
            apply transient_default_working_factory_args using TransientDefaultWorkingFactoryArgContributions
        }

        phase transient_working_working_factory_args after properties_plain order 120
            from arg: TransientWorkingFactoryArgs
            where WorkingFactoryArgOwner == ClassId {
            apply transient_working_working_factory_args using TransientWorkingWorkingFactoryArgContributions
        }

        phase tx_apply_prepared_fields_transient after properties_plain order 290
            from field: IndexedTransientFields
            where FieldOwner == ClassId {
            apply transient_apply_prepared_commit using TransientApplyPreparedCommitContributions
        }

        phase tx_rollback_fields_transient after properties_plain order 320
            from field: IndexedTransientFields
            where FieldOwner == ClassId {
            apply transient_rollback using TransientRollbackContributions
        }
    }
}
