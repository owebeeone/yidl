module tests.lifecycle_managed

import "lifecycle_core.yidl" as core

export concept LifecycleManaged

concept LifecycleManaged extends core.LifecycleCore {

    family core.LifecycleFieldSpec {
        variant ManagedField {
        }
    }

    computed collection ManagedFields: LifecycleFieldSpec from Fields where FieldKind == "managed"

    # -------------------------------------------------------------------------
    # Transaction facts.
    # -------------------------------------------------------------------------

    property TxKeyOrder: int = 0
    property TxOwner: str = ""
    property CommitOrderKeyFunctionName: str = ""
    property RequiresValidationFunctionName: str = ""
    property ValidateCommitFunctionName: str = ""
    property BeforeCommitFunctionName: str = ""
    property AfterCommitFunctionName: str = ""
    property AfterRollbackFunctionName: str = ""
    property PrepareCommitFieldsFunctionName: str = ""
    property ApplyPreparedCommitFieldsFunctionName: str = ""
    property RollbackFieldsFunctionName: str = ""
    record TransactionalField {
        FieldId
        FieldOwner
        FieldName
        FieldOrder
        Compare
        TxKeyKey
    }

    record TxKey {
        TxOwner
        TxKeyKey
        TxIndex
        TxKeyOrder
        CommitOrderKeyFunctionName
        RequiresValidationFunctionName
        ValidateCommitFunctionName
        BeforeCommitFunctionName
        AfterCommitFunctionName
        AfterRollbackFunctionName
        PrepareCommitFieldsFunctionName
        ApplyPreparedCommitFieldsFunctionName
        RollbackFieldsFunctionName
    }

    record IndexedTransactionalField {
        FieldId
        FieldOwner
        FieldName
        FieldOrder
        Compare
        TxKeyKey
        TxIndex
        CurrentSlotName
        WorkingSlotName
        StagedSlotName
        HasFreeze
        FreezeParamName
        HasThaw
        ThawParamName
        HasOptionalNone
    }

    collection TransactionalFields: TransactionalField identity FieldId many
    collection TxKeys: TxKey identity (TxOwner, TxKeyKey) many
    collection IndexedTransactionalFields: IndexedTransactionalField identity FieldId many

    resource BuildTransactionFactsBody = code $[
        from yidl.runtime.transaction_yidl import DEFAULT_TRANSACTION

        classes = sorted(
            ctx.records(ClassesCollection),
            key=lambda item: item.class_order,
        )
        fields = sorted(
            ctx.records(FieldsCollection),
            key=lambda item: item.field_order,
        )

        for lifecycle_class in classes:
            seen = {DEFAULT_TRANSACTION: 0}
            ctx.write(
                TxKeysCollection,
                TxKey(
                    tx_owner=lifecycle_class.class_id,
                    tx_key_key=DEFAULT_TRANSACTION,
                    tx_index=0,
                    tx_key_order=0,
                    commit_order_key_function_name="_commit_order_key_tx_0",
                    requires_validation_function_name="_requires_validation_tx_0",
                    validate_commit_function_name="_validate_commit_tx_0",
                    before_commit_function_name="_before_commit_tx_0",
                    after_commit_function_name="_after_commit_tx_0",
                    after_rollback_function_name="_after_rollback_tx_0",
                    prepare_commit_fields_function_name="_prepare_commit_tx_0_fields",
                    apply_prepared_commit_fields_function_name="_apply_prepared_commit_tx_0_fields",
                    rollback_fields_function_name="_rollback_tx_0_fields",
                ),
                policy=RejectDuplicate,
            )

            for field in fields:
                if field.field_owner != lifecycle_class.class_id:
                    continue
                if field.field_kind not in {"managed", "owned", "transient"}:
                    continue

                tx_key = field.tx_key_key
                if tx_key is None:
                    tx_key = DEFAULT_TRANSACTION
                if tx_key not in seen:
                    seen[tx_key] = len(seen)
                    ctx.write(
                        TxKeysCollection,
                        TxKey(
                            tx_owner=lifecycle_class.class_id,
                            tx_key_key=tx_key,
                            tx_index=seen[tx_key],
                            tx_key_order=field.field_order,
                            commit_order_key_function_name=(
                                f"_commit_order_key_tx_{seen[tx_key]}"
                            ),
                            requires_validation_function_name=(
                                f"_requires_validation_tx_{seen[tx_key]}"
                            ),
                            validate_commit_function_name=(
                                f"_validate_commit_tx_{seen[tx_key]}"
                            ),
                            before_commit_function_name=(
                                f"_before_commit_tx_{seen[tx_key]}"
                            ),
                            after_commit_function_name=(
                                f"_after_commit_tx_{seen[tx_key]}"
                            ),
                            after_rollback_function_name=(
                                f"_after_rollback_tx_{seen[tx_key]}"
                            ),
                            prepare_commit_fields_function_name=(
                                f"_prepare_commit_tx_{seen[tx_key]}_fields"
                            ),
                            apply_prepared_commit_fields_function_name=(
                                f"_apply_prepared_commit_tx_{seen[tx_key]}_fields"
                            ),
                            rollback_fields_function_name=(
                                f"_rollback_tx_{seen[tx_key]}_fields"
                            ),
                        ),
                        policy=RejectDuplicate,
                    )

                tx_index = seen[tx_key]
                ctx.write(
                    TransactionalFieldsCollection,
                    TransactionalField(
                        field_id=field.field_id,
                        field_owner=field.field_owner,
                        field_name=field.field_name,
                        field_order=field.field_order,
                        compare=field.compare,
                        tx_key_key=tx_key,
                    ),
                    policy=RejectDuplicate,
                )
                if field.field_kind != "managed":
                    continue
                ctx.write(
                    IndexedTransactionalFieldsCollection,
                    IndexedTransactionalField(
                        field_id=field.field_id,
                        field_owner=field.field_owner,
                        field_name=field.field_name,
                        field_order=field.field_order,
                        compare=field.compare,
                        tx_key_key=tx_key,
                        tx_index=tx_index,
                        current_slot_name=field.current_slot_name,
                        working_slot_name=field.working_slot_name,
                        staged_slot_name=field.staged_slot_name,
                        has_freeze=field.has_freeze,
                        freeze_param_name=field.freeze_param_name,
                        has_thaw=field.has_thaw,
                        thaw_param_name=field.thaw_param_name,
                        has_optional_none=field.has_optional_none,
                    ),
                    policy=RejectDuplicate,
                )
    ]$ {
        keep ctx, ClassesCollection, FieldsCollection
        keep TxKeysCollection, TransactionalFieldsCollection
        keep IndexedTransactionalFieldsCollection
        keep TxKey, TransactionalField, IndexedTransactionalField
        keep RejectDuplicate
    }

    operation BuildTransactionFacts
        inputs(Classes, Fields)
        outputs(TransactionalFields, TxKeys, IndexedTransactionalFields)
        using BuildTransactionFactsBody

    # -------------------------------------------------------------------------
    # Managed lifecycle resources.
    # -------------------------------------------------------------------------

    resource ManagedCurrentStateAssignment = template $[
        astichi_pass(state, outer_bind=True).astichi_ref(external=current_slot)._ = astichi_pass(
            init_value_name__astichi_arg__,
            outer_bind=True,
        )
    ]$

    resource ManagedWorkingStateAssignment = template $[
        astichi_pass(state, outer_bind=True).astichi_ref(external=working_slot)._ = VOID
    ]$ {
        keep VOID
    }

    resource ManagedStagedStateAssignment = template $[
        astichi_pass(state, outer_bind=True).astichi_ref(external=staged_slot)._ = VOID
    ]$ {
        keep VOID
    }

    resource IdentityCompareGuard = template $[
        if astichi_pass(current, outer_bind=True) is astichi_pass(
            next_value,
            outer_bind=True,
        ):
            return
    ]$

    resource ManagedDefaultProperty = template $[
        @property
        def property_getter_name__astichi_arg__(self):
            state = self._y_state
            if state.astichi_ref(external=working_slot) is not VOID:
                return state.astichi_ref(external=working_slot)
            return state.astichi_ref(external=current_slot)

        @property_setter_target_name__astichi_arg__.setter
        def property_setter_name__astichi_arg__(self, value):
            state = self._y_state
            state._y_require_active_transaction(astichi_bind_external(tx_index))
            if state.astichi_ref(external=working_slot) is not VOID:
                current = state.astichi_ref(external=working_slot)
            else:
                current = state.astichi_ref(external=current_slot)
            next_value = value
            with astichi_hole(compare_guard) as astichi_fallback:
                if current == next_value:
                    return
            state._y_ensure_working_transaction(astichi_bind_external(tx_index))
            state.astichi_ref(external=working_slot)._ = next_value
    ]$ {
        keep VOID
    }

    resource ManagedCurrentProperty = template $[
        @property
        def property_getter_name__astichi_arg__(self):
            return self._y_state.astichi_ref(external=current_slot)

        @property_setter_target_name__astichi_arg__.setter
        def property_setter_name__astichi_arg__(self, value):
            del value
            raise AttributeError(
                "current facade is read-only for transactional field "
                + astichi_bind_external(field_name)
            )
    ]$

    resource ManagedWorkingProperty = template $[
        @property
        def property_getter_name__astichi_arg__(self):
            state = self._y_state
            if state.astichi_ref(external=working_slot) is not VOID:
                return state.astichi_ref(external=working_slot)
            return state.astichi_ref(external=current_slot)

        @property_setter_target_name__astichi_arg__.setter
        def property_setter_name__astichi_arg__(self, value):
            state = self._y_state
            state._y_require_active_transaction(astichi_bind_external(tx_index))
            if state.astichi_ref(external=working_slot) is not VOID:
                current = state.astichi_ref(external=working_slot)
            else:
                current = state.astichi_ref(external=current_slot)
            next_value = value
            with astichi_hole(compare_guard) as astichi_fallback:
                if current == next_value:
                    return
            state._y_ensure_working_transaction(astichi_bind_external(tx_index))
            state.astichi_ref(external=working_slot)._ = next_value
    ]$ {
        keep VOID
    }

    resource ManagedThawWorkingProperty = template $[
        @property
        def property_getter_name__astichi_arg__(self):
            state = self._y_state
            if state.astichi_ref(external=working_slot) is not VOID:
                return state.astichi_ref(external=working_slot)
            tx_key = state.__yidl_tx_index_to_key__[
                astichi_bind_external(working_tx_index)
            ]
            if state._y_transaction_manager.active_transaction_for(tx_key) is None:
                return state.astichi_ref(external=current_slot)
            state._y_ensure_working_transaction(astichi_bind_external(working_tx_index))
            next_value = thaw_func_name__astichi_arg__(
                state.astichi_ref(external=current_slot)
            )
            state.astichi_ref(external=working_slot)._ = next_value
            return next_value

        @property_setter_target_name__astichi_arg__.setter
        def property_setter_name__astichi_arg__(self, value):
            state = self._y_state
            state._y_require_active_transaction(astichi_bind_external(working_tx_index))
            if state.astichi_ref(external=working_slot) is not VOID:
                current = state.astichi_ref(external=working_slot)
            else:
                current = thaw_func_name__astichi_arg__(
                    state.astichi_ref(external=current_slot)
                )
            next_value = value
            with astichi_hole(compare_guard) as astichi_fallback:
                if current == next_value:
                    return
            state._y_ensure_working_transaction(astichi_bind_external(working_tx_index))
            state.astichi_ref(external=working_slot)._ = next_value
    ]$ {
        keep VOID
    }

    resource ManagedOptionalThawWorkingProperty = template $[
        @property
        def property_getter_name__astichi_arg__(self):
            state = self._y_state
            if state.astichi_ref(external=working_slot) is not VOID:
                return state.astichi_ref(external=working_slot)
            tx_key = state.__yidl_tx_index_to_key__[
                astichi_bind_external(working_tx_index)
            ]
            if state._y_transaction_manager.active_transaction_for(tx_key) is None:
                return state.astichi_ref(external=current_slot)
            state._y_ensure_working_transaction(astichi_bind_external(working_tx_index))
            current_value = state.astichi_ref(external=current_slot)
            next_value = (
                None
                if current_value is None
                else thaw_func_name__astichi_arg__(current_value)
            )
            state.astichi_ref(external=working_slot)._ = next_value
            return next_value

        @property_setter_target_name__astichi_arg__.setter
        def property_setter_name__astichi_arg__(self, value):
            state = self._y_state
            state._y_require_active_transaction(astichi_bind_external(working_tx_index))
            if state.astichi_ref(external=working_slot) is not VOID:
                current = state.astichi_ref(external=working_slot)
            elif state.astichi_ref(external=current_slot) is None:
                current = None
            else:
                current = thaw_func_name__astichi_arg__(
                    state.astichi_ref(external=current_slot)
                )
            next_value = value
            with astichi_hole(compare_guard) as astichi_fallback:
                if current == next_value:
                    return
            state._y_ensure_working_transaction(astichi_bind_external(working_tx_index))
            state.astichi_ref(external=working_slot)._ = next_value
    ]$ {
        keep VOID
    }

    resource ManagedPlainPrepareBranch = template $[
        if astichi_pass(self, outer_bind=True).astichi_ref(external=working_slot) is not VOID:
            astichi_pass(self, outer_bind=True).astichi_ref(external=staged_slot)._ = (
                astichi_pass(self, outer_bind=True).astichi_ref(external=working_slot)
            )
    ]$ {
        keep VOID
    }

    resource ManagedFreezePrepareBranch = template $[
        if astichi_pass(self, outer_bind=True).astichi_ref(external=working_slot) is not VOID:
            astichi_pass(self, outer_bind=True).astichi_ref(external=staged_slot)._ = (
                freeze_func_name__astichi_arg__(
                    astichi_pass(self, outer_bind=True).astichi_ref(external=working_slot)
                )
            )
    ]$ {
        keep VOID
    }

    resource ManagedOptionalFreezePrepareBranch = template $[
        if astichi_pass(self, outer_bind=True).astichi_ref(external=working_slot) is not VOID:
            astichi_pass(self, outer_bind=True).astichi_ref(external=staged_slot)._ = (
                None
                if astichi_pass(self, outer_bind=True).astichi_ref(external=working_slot) is None
                else freeze_func_name__astichi_arg__(
                    astichi_pass(self, outer_bind=True).astichi_ref(external=working_slot)
                )
            )
    ]$ {
        keep VOID
    }

    resource ManagedApplyPreparedCommitBranch = template $[
        if astichi_pass(self, outer_bind=True).astichi_ref(external=staged_slot) is not VOID:
            astichi_pass(self, outer_bind=True).astichi_ref(external=current_slot)._ = (
                astichi_pass(self, outer_bind=True).astichi_ref(external=staged_slot)
            )
            astichi_pass(self, outer_bind=True).astichi_ref(external=staged_slot)._ = VOID
            astichi_pass(self, outer_bind=True).astichi_ref(external=working_slot)._ = VOID
    ]$ {
        keep VOID
    }

    resource ManagedRollbackBranch = template $[
        astichi_pass(self, outer_bind=True).astichi_ref(external=staged_slot)._ = VOID
        astichi_pass(self, outer_bind=True).astichi_ref(external=working_slot)._ = VOID
    ]$ {
        keep VOID
    }

    resource CommitOrderKeyFunction = template $[
        def commit_order_key_function_name__astichi_arg__(self):
            with astichi_hole(commit_order_key_tx_body) as astichi_fallback:
                pass
            return ()
    ]$

    resource RequiresValidationFunction = template $[
        def requires_validation_function_name__astichi_arg__(self):
            with astichi_hole(requires_validation_tx_body) as astichi_fallback:
                pass
            return False
    ]$

    resource ValidateCommitFunction = template $[
        def validate_commit_function_name__astichi_arg__(self):
            with astichi_hole(validate_commit_tx_body) as astichi_fallback:
                pass
            return True
    ]$

    resource BeforeCommitFunction = template $[
        def before_commit_function_name__astichi_arg__(self):
            with astichi_hole(before_commit_tx_body) as astichi_fallback:
                pass
    ]$

    resource AfterCommitFunction = template $[
        def after_commit_function_name__astichi_arg__(self):
            with astichi_hole(after_commit_tx_body) as astichi_fallback:
                pass
    ]$

    resource AfterRollbackFunction = template $[
        def after_rollback_function_name__astichi_arg__(self):
            with astichi_hole(after_rollback_tx_body) as astichi_fallback:
                pass
    ]$

    resource CommitOrderKeyHelperCall = template $[
        return astichi_pass(
            self,
            outer_bind=True,
        )._y_get_default_facade().astichi_ref(external=method_name)()
    ]$

    resource RequiresValidationHelperCall = template $[
        return True
    ]$

    resource ValidateCommitHelperCall = template $[
        result = astichi_pass(
            self,
            outer_bind=True,
        )._y_get_default_facade().astichi_ref(external=method_name)()
        if not result:
            return result
    ]$

    resource TransactionHookHelperCall = template $[
        astichi_pass(
            self,
            outer_bind=True,
        )._y_get_default_facade().astichi_ref(external=method_name)()
    ]$

    resource CommitOrderKeyDispatchCall = template $[
        def astichi_elif():
            astichi_import(tx_index)
            astichi_import(self)

            if tx_index == astichi_bind_external(tx_index_value):
                return self.astichi_ref(external=commit_order_key_function_name)()
    ]$

    resource RequiresValidationDispatchCall = template $[
        def astichi_elif():
            astichi_import(tx_index)
            astichi_import(self)

            if tx_index == astichi_bind_external(tx_index_value):
                return self.astichi_ref(external=requires_validation_function_name)()
    ]$

    resource ValidateCommitDispatchCall = template $[
        def astichi_elif():
            astichi_import(tx_index)
            astichi_import(self)

            if tx_index == astichi_bind_external(tx_index_value):
                return self.astichi_ref(external=validate_commit_function_name)()
    ]$

    resource BeforeCommitDispatchCall = template $[
        def astichi_elif():
            astichi_import(tx_index)
            astichi_import(self)

            if tx_index == astichi_bind_external(tx_index_value):
                self.astichi_ref(external=before_commit_function_name)()
    ]$

    resource AfterCommitDispatchCall = template $[
        def astichi_elif():
            astichi_import(tx_index)
            astichi_import(self)

            if tx_index == astichi_bind_external(tx_index_value):
                self.astichi_ref(external=after_commit_function_name)()
    ]$

    resource AfterRollbackDispatchCall = template $[
        def astichi_elif():
            astichi_import(tx_index)
            astichi_import(self)

            if tx_index == astichi_bind_external(tx_index_value):
                self.astichi_ref(external=after_rollback_function_name)()
    ]$

    resource PrepareCommitFieldsFunction = template $[
        def prepare_commit_fields_function_name__astichi_arg__(self):
            with astichi_hole(prepare_commit_fields_body) as astichi_fallback:
                pass
    ]$

    resource ApplyPreparedCommitFieldsFunction = template $[
        def apply_prepared_commit_fields_function_name__astichi_arg__(self):
            with astichi_hole(apply_prepared_commit_fields_body) as astichi_fallback:
                pass
    ]$

    resource RollbackFieldsFunction = template $[
        def rollback_fields_function_name__astichi_arg__(self):
            with astichi_hole(rollback_fields_body) as astichi_fallback:
                pass
    ]$

    resource ApplyPreparedCommitDispatchBranch = template $[
        def astichi_elif():
            astichi_import(tx_index)
            astichi_import(self)

            if tx_index == astichi_bind_external(tx_index_value):
                self.astichi_ref(external=apply_prepared_commit_fields_function_name)()
    ]$

    resource PrepareCommitDispatchBranch = template $[
        def astichi_elif():
            astichi_import(tx_index)
            astichi_import(self)

            if tx_index == astichi_bind_external(tx_index_value):
                self.astichi_ref(external=prepare_commit_fields_function_name)()
    ]$

    resource RollbackDispatchBranch = template $[
        def astichi_elif():
            astichi_import(tx_index)
            astichi_import(self)

            if tx_index == astichi_bind_external(tx_index_value):
                self.astichi_ref(external=rollback_fields_function_name)()
    ]$

    contribution ManagedCurrentStateSlot = StateSlotEntry {
        as ManagedCurrentStateSlot
        index FieldOrder
        order FieldOrder

        target state_slots {
            build /ClassDef
        }

        external slot_name = CurrentSlotName
    }

    contribution ManagedWorkingStateSlot = StateSlotEntry {
        as ManagedWorkingStateSlot
        index FieldOrder
        order FieldOrder

        target state_slots {
            build /ClassDef
        }

        external slot_name = WorkingSlotName
    }

    contribution ManagedStagedStateSlot = StateSlotEntry {
        as ManagedStagedStateSlot
        index FieldOrder
        order FieldOrder

        target state_slots {
            build /ClassDef
        }

        external slot_name = StagedSlotName
    }

    contribution ManagedFreezeBuilderParam = BuilderParam {
        as ManagedFreezeBuilderParam
        index FieldOrder
        order FieldOrder

        target builder_params {
            build /Root
        }

        ident value_name = FreezeParamName
    }

    contribution ManagedThawBuilderParam = BuilderParam {
        as ManagedThawBuilderParam
        index FieldOrder
        order FieldOrder

        target builder_params {
            build /Root
        }

        ident value_name = ThawParamName
    }

    contribution ManagedInitParamDefault = InitParamDefault {
        as ManagedInitParam
        index FieldOrder
        order FieldOrder

        target init_params {
            build /ClassDef
        }

        ident param_name = FieldName
        external annotation = Annotation
        ident default_value_name = DefaultValueParamName
    }

    contribution ManagedInitParamRequired = InitParamRequired {
        as ManagedInitParam
        index FieldOrder
        order FieldOrder

        target init_params {
            build /ClassDef
        }

        ident param_name = FieldName
        external annotation = Annotation
    }

    contribution ManagedCurrentInitAssignment = ManagedCurrentStateAssignment {
        as ManagedCurrentInitAssignment
        index FieldOrder
        order FieldOrder

        target state_init_body {
            build /ClassDef
        }

        ident init_value_name = FieldName
        external current_slot = CurrentSlotName
    }

    contribution ManagedCurrentDefaultAssignment = ManagedCurrentStateAssignment {
        as ManagedCurrentDefaultAssignment
        index FieldOrder
        order FieldOrder

        target state_init_body {
            build /ClassDef
        }

        ident init_value_name = DefaultValueParamName
        external current_slot = CurrentSlotName
    }

    contribution ManagedWorkingInitAssignment = ManagedWorkingStateAssignment {
        as ManagedWorkingInitAssignment
        index FieldOrder
        order FieldOrder

        target state_init_body {
            build /ClassDef
        }

        external working_slot = WorkingSlotName
    }

    contribution ManagedStagedInitAssignment = ManagedStagedStateAssignment {
        as ManagedStagedInitAssignment
        index FieldOrder
        order FieldOrder

        target state_init_body {
            build /ClassDef
        }

        external staged_slot = StagedSlotName
    }

    contribution ManagedDefaultFacadeProperty = ManagedDefaultProperty {
        as ManagedDefaultFacadeProperty
        index FieldOrder
        order FieldOrder

        target default_facade_properties {
            build /ClassDef
        }

        ident property_getter_name = FieldName
        ident property_setter_target_name = FieldName
        ident property_setter_name = FieldName
        external current_slot = CurrentSlotName
        external working_slot = WorkingSlotName
        external tx_index = TxIndex
    }

    contribution ManagedDefaultIdentityCompareGuard = IdentityCompareGuard {
        index FieldOrder
        order FieldOrder

        target compare_guard {
            build /ClassDef/ManagedDefaultFacadeProperty[FieldOrder]
        }
    }

    contribution ManagedCurrentFacadeProperty = ManagedCurrentProperty {
        as ManagedCurrentFacadeProperty
        index FieldOrder
        order FieldOrder

        target current_facade_properties {
            build /ClassDef
        }

        ident property_getter_name = FieldName
        ident property_setter_target_name = FieldName
        ident property_setter_name = FieldName
        external current_slot = CurrentSlotName
        external field_name = FieldName
    }

    contribution ManagedWorkingFacadeProperty = ManagedWorkingProperty {
        as ManagedWorkingFacadeProperty
        index FieldOrder
        order FieldOrder

        target working_facade_properties {
            build /ClassDef
        }

        ident property_getter_name = FieldName
        ident property_setter_target_name = FieldName
        ident property_setter_name = FieldName
        external current_slot = CurrentSlotName
        external working_slot = WorkingSlotName
        external tx_index = TxIndex
    }

    contribution ManagedWorkingIdentityCompareGuard = IdentityCompareGuard {
        index FieldOrder
        order FieldOrder

        target compare_guard {
            build /ClassDef/ManagedWorkingFacadeProperty[FieldOrder]
        }
    }

    contribution ManagedThawWorkingFacadeProperty = ManagedThawWorkingProperty {
        as ManagedWorkingFacadeProperty
        index FieldOrder
        order FieldOrder

        target working_facade_properties {
            build /ClassDef
        }

        ident property_getter_name = FieldName
        ident property_setter_target_name = FieldName
        ident property_setter_name = FieldName
        external current_slot = CurrentSlotName
        external working_slot = WorkingSlotName
        external working_tx_index = TxIndex
        ident thaw_func_name = ThawParamName
    }

    contribution ManagedOptionalThawWorkingFacadeProperty = ManagedOptionalThawWorkingProperty {
        as ManagedWorkingFacadeProperty
        index FieldOrder
        order FieldOrder

        target working_facade_properties {
            build /ClassDef
        }

        ident property_getter_name = FieldName
        ident property_setter_target_name = FieldName
        ident property_setter_name = FieldName
        external current_slot = CurrentSlotName
        external working_slot = WorkingSlotName
        external working_tx_index = TxIndex
        ident thaw_func_name = ThawParamName
    }

    contribution ManagedPlainPrepareCommit = ManagedPlainPrepareBranch {
        as ManagedPrepareCommit
        index FieldOrder
        order FieldOrder

        target prepare_commit_fields_body {
            build /ClassDef/PrepareCommitFields[TxIndex]
        }

        external working_slot = WorkingSlotName
        external staged_slot = StagedSlotName
    }

    contribution ManagedFreezePrepareCommit = ManagedFreezePrepareBranch {
        as ManagedPrepareCommit
        index FieldOrder
        order FieldOrder

        target prepare_commit_fields_body {
            build /ClassDef/PrepareCommitFields[TxIndex]
        }

        external working_slot = WorkingSlotName
        external staged_slot = StagedSlotName
        ident freeze_func_name = FreezeParamName
    }

    contribution ManagedOptionalFreezePrepareCommit = ManagedOptionalFreezePrepareBranch {
        as ManagedPrepareCommit
        index FieldOrder
        order FieldOrder

        target prepare_commit_fields_body {
            build /ClassDef/PrepareCommitFields[TxIndex]
        }

        external working_slot = WorkingSlotName
        external staged_slot = StagedSlotName
        ident freeze_func_name = FreezeParamName
    }

    contribution ManagedApplyPreparedCommit = ManagedApplyPreparedCommitBranch {
        as ManagedApplyPreparedCommit
        index FieldOrder
        order FieldOrder

        target apply_prepared_commit_fields_body {
            build /ClassDef/ApplyPreparedCommitFields[TxIndex]
        }

        external current_slot = CurrentSlotName
        external working_slot = WorkingSlotName
        external staged_slot = StagedSlotName
    }

    contribution ManagedRollback = ManagedRollbackBranch {
        as ManagedRollback
        index FieldOrder
        order FieldOrder

        target rollback_fields_body {
            build /ClassDef/RollbackFields[TxIndex]
        }

        external working_slot = WorkingSlotName
        external staged_slot = StagedSlotName
    }

    contribution CommitOrderKeyHelper = CommitOrderKeyFunction {
        as CommitOrderKeyFunction
        index TxIndex
        order TxIndex

        target commit_transaction_helpers {
            build /ClassDef
        }

        ident commit_order_key_function_name = CommitOrderKeyFunctionName
    }

    contribution RequiresValidationHelper = RequiresValidationFunction {
        as RequiresValidationFunction
        index TxIndex
        order TxIndex

        target commit_transaction_helpers {
            build /ClassDef
        }

        ident requires_validation_function_name = RequiresValidationFunctionName
    }

    contribution ValidateCommitHelper = ValidateCommitFunction {
        as ValidateCommitFunction
        index TxIndex
        order TxIndex

        target commit_transaction_helpers {
            build /ClassDef
        }

        ident validate_commit_function_name = ValidateCommitFunctionName
    }

    contribution BeforeCommitHelper = BeforeCommitFunction {
        as BeforeCommitFunction
        index TxIndex
        order TxIndex

        target commit_transaction_helpers {
            build /ClassDef
        }

        ident before_commit_function_name = BeforeCommitFunctionName
    }

    contribution AfterCommitHelper = AfterCommitFunction {
        as AfterCommitFunction
        index TxIndex
        order TxIndex

        target commit_transaction_helpers {
            build /ClassDef
        }

        ident after_commit_function_name = AfterCommitFunctionName
    }

    contribution AfterRollbackHelper = AfterRollbackFunction {
        as AfterRollbackFunction
        index TxIndex
        order TxIndex

        target rollback_transaction_helpers {
            build /ClassDef
        }

        ident after_rollback_function_name = AfterRollbackFunctionName
    }

    contribution CommitOrderKeyDispatch = CommitOrderKeyDispatchCall {
        as CommitOrderKeyDispatch
        index TxIndex
        order TxIndex

        target commit_order_key_body {
            build /ClassDef
        }

        external commit_order_key_function_name = CommitOrderKeyFunctionName
        external tx_index_value = TxIndex
    }

    contribution RequiresValidationDispatch = RequiresValidationDispatchCall {
        as RequiresValidationDispatch
        index TxIndex
        order TxIndex

        target requires_validation_body {
            build /ClassDef
        }

        external requires_validation_function_name = RequiresValidationFunctionName
        external tx_index_value = TxIndex
    }

    contribution ValidateCommitDispatch = ValidateCommitDispatchCall {
        as ValidateCommitDispatch
        index TxIndex
        order TxIndex

        target validate_commit_body {
            build /ClassDef
        }

        external validate_commit_function_name = ValidateCommitFunctionName
        external tx_index_value = TxIndex
    }

    contribution BeforeCommitDispatch = BeforeCommitDispatchCall {
        as BeforeCommitDispatch
        index TxIndex
        order TxIndex

        target before_commit_body {
            build /ClassDef
        }

        external before_commit_function_name = BeforeCommitFunctionName
        external tx_index_value = TxIndex
    }

    contribution AfterCommitDispatch = AfterCommitDispatchCall {
        as AfterCommitDispatch
        index TxIndex
        order TxIndex

        target after_commit_body {
            build /ClassDef
        }

        external after_commit_function_name = AfterCommitFunctionName
        external tx_index_value = TxIndex
    }

    contribution AfterRollbackDispatch = AfterRollbackDispatchCall {
        as AfterRollbackDispatch
        index TxIndex
        order TxIndex

        target after_rollback_body {
            build /ClassDef
        }

        external after_rollback_function_name = AfterRollbackFunctionName
        external tx_index_value = TxIndex
    }

    contribution CommitOrderKeyHelperMethodCall = CommitOrderKeyHelperCall {
        as CommitOrderKeyHelperMethodCall
        index DeclarationOrder
        order DeclarationOrder

        target commit_order_key_tx_body {
            build /ClassDef/CommitOrderKeyFunction[TxIndex]
        }

        external method_name = MethodName
    }

    contribution RequiresValidationHelperMethodCall = RequiresValidationHelperCall {
        as RequiresValidationHelperMethodCall
        index DeclarationOrder
        order DeclarationOrder

        target requires_validation_tx_body {
            build /ClassDef/RequiresValidationFunction[TxIndex]
        }
    }

    contribution ValidateCommitHelperMethodCall = ValidateCommitHelperCall {
        as ValidateCommitHelperMethodCall
        index DeclarationOrder
        order DeclarationOrder

        target validate_commit_tx_body {
            build /ClassDef/ValidateCommitFunction[TxIndex]
        }

        external method_name = MethodName
    }

    contribution BeforeCommitHelperMethodCall = TransactionHookHelperCall {
        as BeforeCommitHelperMethodCall
        index DeclarationOrder
        order DeclarationOrder

        target before_commit_tx_body {
            build /ClassDef/BeforeCommitFunction[TxIndex]
        }

        external method_name = MethodName
    }

    contribution AfterCommitHelperMethodCall = TransactionHookHelperCall {
        as AfterCommitHelperMethodCall
        index DeclarationOrder
        order DeclarationOrder

        target after_commit_tx_body {
            build /ClassDef/AfterCommitFunction[TxIndex]
        }

        external method_name = MethodName
    }

    contribution AfterRollbackHelperMethodCall = TransactionHookHelperCall {
        as AfterRollbackHelperMethodCall
        index DeclarationOrder
        order DeclarationOrder

        target after_rollback_tx_body {
            build /ClassDef/AfterRollbackFunction[TxIndex]
        }

        external method_name = MethodName
    }

    contribution PrepareCommitFields = PrepareCommitFieldsFunction {
        as PrepareCommitFields
        index TxIndex
        order TxIndex

        target commit_transaction_helpers {
            build /ClassDef
        }

        ident prepare_commit_fields_function_name = PrepareCommitFieldsFunctionName
    }

    contribution ApplyPreparedCommitFields = ApplyPreparedCommitFieldsFunction {
        as ApplyPreparedCommitFields
        index TxIndex
        order TxIndex

        target commit_transaction_helpers {
            build /ClassDef
        }

        ident apply_prepared_commit_fields_function_name = ApplyPreparedCommitFieldsFunctionName
    }

    contribution RollbackFields = RollbackFieldsFunction {
        as RollbackFields
        index TxIndex
        order TxIndex

        target rollback_transaction_helpers {
            build /ClassDef
        }

        ident rollback_fields_function_name = RollbackFieldsFunctionName
    }

    contribution PrepareCommitDispatch = PrepareCommitDispatchBranch {
        as PrepareCommitDispatch
        index TxIndex
        order TxIndex

        target prepare_commit_transaction_dispatch_body {
            build /ClassDef
        }

        external prepare_commit_fields_function_name = PrepareCommitFieldsFunctionName
        external tx_index_value = TxIndex
    }

    contribution ApplyPreparedCommitDispatch = ApplyPreparedCommitDispatchBranch {
        as ApplyPreparedCommitDispatch
        index TxIndex
        order TxIndex

        target commit_transaction_dispatch_body {
            build /ClassDef
        }

        external apply_prepared_commit_fields_function_name = ApplyPreparedCommitFieldsFunctionName
        external tx_index_value = TxIndex
    }

    contribution RollbackDispatch = RollbackDispatchBranch {
        as RollbackDispatch
        index TxIndex
        order TxIndex

        target rollback_transaction_dispatch_body {
            build /ClassDef
        }

        external rollback_fields_function_name = RollbackFieldsFunctionName
        external tx_index_value = TxIndex
    }

    matcher ManagedCurrentStateSlotContributions(field: ManagedFields) -> contribution {
        default -> ManagedCurrentStateSlot
    }

    matcher ManagedWorkingStateSlotContributions(field: ManagedFields) -> contribution {
        default -> ManagedWorkingStateSlot
    }

    matcher ManagedStagedStateSlotContributions(field: ManagedFields) -> contribution {
        default -> ManagedStagedStateSlot
    }

    matcher ManagedFreezeBuilderParamContributions(field: ManagedFields) -> contribution {
        rule has_freeze when HasFreeze == True -> ManagedFreezeBuilderParam
    }

    matcher ManagedThawBuilderParamContributions(field: ManagedFields) -> contribution {
        rule has_thaw when HasThaw == True -> ManagedThawBuilderParam
    }

    matcher ManagedCurrentInitAssignmentContributions(field: ManagedFields) -> contribution {
        rule init_field when Init == True
                        and HasDefaultFactory == False
                        -> ManagedCurrentInitAssignment
        rule default_value when Init == False
                           and HasDefault == True
                           and HasDefaultFactory == False
                           -> ManagedCurrentDefaultAssignment
    }

    matcher ManagedWorkingInitAssignmentContributions(field: ManagedFields) -> contribution {
        default -> ManagedWorkingInitAssignment
    }

    matcher ManagedStagedInitAssignmentContributions(field: ManagedFields) -> contribution {
        default -> ManagedStagedInitAssignment
    }

    matcher ManagedDefaultFacadePropertyContributions(field: IndexedTransactionalFields) -> contribution {
        default -> ManagedDefaultFacadeProperty
    }

    matcher ManagedCurrentFacadePropertyContributions(field: IndexedTransactionalFields) -> contribution {
        default -> ManagedCurrentFacadeProperty
    }

    matcher ManagedWorkingFacadePropertyContributions(field: IndexedTransactionalFields) -> contribution {
        default -> ManagedWorkingFacadeProperty
        rule with_optional_thaw when HasThaw == True
                                and HasOptionalNone == True
                                -> ManagedOptionalThawWorkingFacadeProperty
        rule with_thaw when HasThaw == True -> ManagedThawWorkingFacadeProperty
    }

    matcher ManagedDefaultCompareGuardContributions(field: IndexedTransactionalFields) -> contribution {
        rule identity when Compare == "identity" -> ManagedDefaultIdentityCompareGuard
    }

    matcher ManagedWorkingCompareGuardContributions(field: IndexedTransactionalFields) -> contribution {
        rule identity when Compare == "identity" -> ManagedWorkingIdentityCompareGuard
    }

    matcher ManagedPrepareCommitContributions(field: IndexedTransactionalFields) -> contribution {
        default -> ManagedPlainPrepareCommit
        rule with_optional_freeze when HasFreeze == True
                                  and HasOptionalNone == True
                                  -> ManagedOptionalFreezePrepareCommit
        rule with_freeze when HasFreeze == True -> ManagedFreezePrepareCommit
    }

    matcher ManagedApplyPreparedCommitContributions(field: IndexedTransactionalFields) -> contribution {
        default -> ManagedApplyPreparedCommit
    }

    matcher ManagedRollbackContributions(field: IndexedTransactionalFields) -> contribution {
        default -> ManagedRollback
    }

    matcher CommitOrderKeyHelperContributions(tx_key: TxKeys) -> contribution {
        default -> CommitOrderKeyHelper
    }

    matcher RequiresValidationHelperContributions(tx_key: TxKeys) -> contribution {
        default -> RequiresValidationHelper
    }

    matcher ValidateCommitHelperContributions(tx_key: TxKeys) -> contribution {
        default -> ValidateCommitHelper
    }

    matcher BeforeCommitHelperContributions(tx_key: TxKeys) -> contribution {
        default -> BeforeCommitHelper
    }

    matcher AfterCommitHelperContributions(tx_key: TxKeys) -> contribution {
        default -> AfterCommitHelper
    }

    matcher AfterRollbackHelperContributions(tx_key: TxKeys) -> contribution {
        default -> AfterRollbackHelper
    }

    matcher CommitOrderKeyDispatchContributions(tx_key: TxKeys) -> contribution {
        default -> CommitOrderKeyDispatch
    }

    matcher RequiresValidationDispatchContributions(tx_key: TxKeys) -> contribution {
        default -> RequiresValidationDispatch
    }

    matcher ValidateCommitDispatchContributions(tx_key: TxKeys) -> contribution {
        default -> ValidateCommitDispatch
    }

    matcher BeforeCommitDispatchContributions(tx_key: TxKeys) -> contribution {
        default -> BeforeCommitDispatch
    }

    matcher AfterCommitDispatchContributions(tx_key: TxKeys) -> contribution {
        default -> AfterCommitDispatch
    }

    matcher AfterRollbackDispatchContributions(tx_key: TxKeys) -> contribution {
        default -> AfterRollbackDispatch
    }

    matcher CommitOrderKeyContributions(method: CommitOrderKeyProviders) -> contribution {
        rule helper when MethodKind == "commit_order_key" -> CommitOrderKeyHelperMethodCall
    }

    matcher RequiresValidationContributions(method: CommitValidators) -> contribution {
        rule helper when MethodKind == "validate_commit" -> RequiresValidationHelperMethodCall
    }

    matcher ValidateCommitContributions(method: CommitValidators) -> contribution {
        rule helper when MethodKind == "validate_commit" -> ValidateCommitHelperMethodCall
    }

    matcher BeforeCommitHookContributions(method: BeforeCommitHooks) -> contribution {
        rule helper when MethodKind == "before_commit" -> BeforeCommitHelperMethodCall
    }

    matcher AfterCommitHookContributions(method: AfterCommitHooks) -> contribution {
        rule helper when MethodKind == "after_commit" -> AfterCommitHelperMethodCall
    }

    matcher AfterRollbackHookContributions(method: AfterRollbackHooks) -> contribution {
        rule helper when MethodKind == "after_rollback" -> AfterRollbackHelperMethodCall
    }

    matcher ApplyPreparedCommitFieldsContributions(tx_key: TxKeys) -> contribution {
        default -> ApplyPreparedCommitFields
    }

    matcher PrepareCommitFieldsContributions(tx_key: TxKeys) -> contribution {
        default -> PrepareCommitFields
    }

    matcher RollbackFieldsContributions(tx_key: TxKeys) -> contribution {
        default -> RollbackFields
    }

    matcher PrepareCommitDispatchContributions(tx_key: TxKeys) -> contribution {
        default -> PrepareCommitDispatch
    }

    matcher ApplyPreparedCommitDispatchContributions(tx_key: TxKeys) -> contribution {
        default -> ApplyPreparedCommitDispatch
    }

    matcher RollbackDispatchContributions(tx_key: TxKeys) -> contribution {
        default -> RollbackDispatch
    }

    matcher ManagedInitParamContributions(field: ManagedFields) -> contribution {
        rule required when Init == True
                      and HasDefault == False
                      and HasDefaultFactory == False
                      -> ManagedInitParamRequired
        rule default_value when Init == True
                           and HasDefault == True
                           and HasDefaultFactory == False
                           -> ManagedInitParamDefault
    }

    extend production CoreModuleProduction {
        phase managed_freeze_params after field_default_params order 30
            from field: ManagedFields {
            apply managed_freeze_params using ManagedFreezeBuilderParamContributions
        }

        phase managed_thaw_params after field_default_params order 40
            from field: ManagedFields {
            apply managed_thaw_params using ManagedThawBuilderParamContributions
        }
    }

    extend production CoreClassProduction {
        phase state_slots_managed_current after state_slots_plain order 50
            from field: ManagedFields
            where FieldOwner == ClassId {
            apply managed_current_state_slots using ManagedCurrentStateSlotContributions
        }

        phase state_slots_managed_working after state_slots_plain order 70
            from field: ManagedFields
            where FieldOwner == ClassId {
            apply managed_working_state_slots using ManagedWorkingStateSlotContributions
        }

        phase state_slots_managed_staged after state_slots_plain order 100
            from field: ManagedFields
            where FieldOwner == ClassId {
            apply managed_staged_state_slots using ManagedStagedStateSlotContributions
        }

        phase tx_key_helpers after tx_fallbacks order 10
            from tx_key: TxKeys
            where TxOwner == ClassId {
            apply commit_order_key_helpers using CommitOrderKeyHelperContributions
            apply requires_validation_helpers using RequiresValidationHelperContributions
            apply validate_commit_helpers using ValidateCommitHelperContributions
            apply before_commit_helpers using BeforeCommitHelperContributions
            apply after_commit_helpers using AfterCommitHelperContributions
            apply after_rollback_helpers using AfterRollbackHelperContributions
        }

        phase tx_key_dispatch after tx_fallbacks order 20
            from tx_key: TxKeys
            where TxOwner == ClassId {
            apply commit_order_key_dispatch using CommitOrderKeyDispatchContributions
            apply requires_validation_dispatch using RequiresValidationDispatchContributions
            apply validate_commit_dispatch using ValidateCommitDispatchContributions
            apply before_commit_dispatch using BeforeCommitDispatchContributions
            apply after_commit_dispatch using AfterCommitDispatchContributions
            apply after_rollback_dispatch using AfterRollbackDispatchContributions
        }

        phase init_params_managed after init_params_initvar order 10
            from field: ManagedFields
            where FieldOwner == ClassId {
            apply managed_init_params using ManagedInitParamContributions
        }

        phase init_assignments_managed_current after init_assignments_plain order 30
            from field: ManagedFields
            where FieldOwner == ClassId {
            apply managed_current_init_assignments using ManagedCurrentInitAssignmentContributions
        }

        phase init_assignments_managed_working after init_assignments_plain order 50
            from field: ManagedFields
            where FieldOwner == ClassId {
            apply managed_working_init_assignments using ManagedWorkingInitAssignmentContributions
        }

        phase init_assignments_managed_staged after init_assignments_plain order 100
            from field: ManagedFields
            where FieldOwner == ClassId {
            apply managed_staged_init_assignments using ManagedStagedInitAssignmentContributions
        }

        phase properties_managed_default after properties_plain order 30
            from field: IndexedTransactionalFields
            where FieldOwner == ClassId {
            apply managed_default_properties using ManagedDefaultFacadePropertyContributions
            apply managed_default_compare_guards using ManagedDefaultCompareGuardContributions
        }

        phase properties_managed_current after properties_plain order 50
            from field: IndexedTransactionalFields
            where FieldOwner == ClassId {
            apply managed_current_properties using ManagedCurrentFacadePropertyContributions
        }

        phase properties_managed_working after properties_plain order 80
            from field: IndexedTransactionalFields
            where FieldOwner == ClassId {
            apply managed_working_properties using ManagedWorkingFacadePropertyContributions
            apply managed_working_compare_guards using ManagedWorkingCompareGuardContributions
        }

        phase tx_apply_prepared_helpers after properties_plain order 200
            from tx_key: TxKeys
            where TxOwner == ClassId {
            apply apply_prepared_commit_helpers using ApplyPreparedCommitFieldsContributions
        }

        phase tx_prepare_helpers after properties_plain order 210
            from tx_key: TxKeys
            where TxOwner == ClassId {
            apply prepare_commit_helpers using PrepareCommitFieldsContributions
        }

        phase tx_rollback_helpers after properties_plain order 220
            from tx_key: TxKeys
            where TxOwner == ClassId {
            apply rollback_helpers using RollbackFieldsContributions
        }

        phase tx_prepare_dispatch after properties_plain order 230
            from tx_key: TxKeys
            where TxOwner == ClassId {
            apply prepare_commit_dispatch using PrepareCommitDispatchContributions
        }

        phase tx_apply_prepared_dispatch after properties_plain order 240
            from tx_key: TxKeys
            where TxOwner == ClassId {
            apply apply_prepared_commit_dispatch using ApplyPreparedCommitDispatchContributions
        }

        phase tx_rollback_dispatch after properties_plain order 250
            from tx_key: TxKeys
            where TxOwner == ClassId {
            apply rollback_dispatch using RollbackDispatchContributions
        }

        phase tx_prepare_fields_managed after properties_plain order 260
            from field: IndexedTransactionalFields
            where FieldOwner == ClassId {
            apply managed_prepare_commit using ManagedPrepareCommitContributions
        }

        phase tx_apply_prepared_fields_managed after properties_plain order 270
            from field: IndexedTransactionalFields
            where FieldOwner == ClassId {
            apply managed_apply_prepared_commit using ManagedApplyPreparedCommitContributions
        }

        phase tx_rollback_fields_managed after properties_plain order 300
            from field: IndexedTransactionalFields
            where FieldOwner == ClassId {
            apply managed_rollback using ManagedRollbackContributions
        }
    }

}
