module tests.lifecycle_base

import "lifecycle_owned.yidl" as owned

export concept LifecycleBase

concept LifecycleBase extends owned.LifecycleOwned {

    # -------------------------------------------------------------------------
    # Final lifecycle assembly.
    # -------------------------------------------------------------------------

    contribution ClassDefinition = ClassProduction {
        as ClassDef
        index ClassOrder
        order ClassOrder

        target function_body {
            build /Root
        }
    }

    matcher ClassDefinitionContributions(lifecycle_class: Classes) -> contribution {
        default -> ClassDefinition
    }

    production ModuleProduction -> composable {
        root Root = ModuleRoot

        apply lifecycle_definition_params
            from lifecycle_class: Classes
            using BuilderParamContributions

        apply annotations_params
            from lifecycle_class: Classes
            using AnnotationsBuilderParamContributions

        apply tx_groups_params
            from lifecycle_class: Classes
            using TxGroupsBuilderParamContributions

        apply field_default_params
            from field: Fields
            using FieldDefaultBuilderParamContributions

        apply transient_working_default_params
            from field: Fields
            using TransientWorkingDefaultBuilderParamContributions

        apply binding_support_helpers
            from lifecycle_class: Classes
            using BindingSupportHelperContributions

        apply managed_freeze_params
            from field: ManagedFields
            using ManagedFreezeBuilderParamContributions

        apply managed_thaw_params
            from field: ManagedFields
            using ManagedThawBuilderParamContributions

        apply classes
            from lifecycle_class: Classes
            using ClassDefinitionContributions

        apply return_class
            from lifecycle_class: Classes
            using ReturnClassContributions
    }

    production ClassProduction(lifecycle_class: Classes) -> composable {
        root ClassDef = ClassBundle {
            ident state_class_decl_name = StateClassName
            ident state_class_ref = StateClassName
            ident default_facade_class_decl_name = ClassName
            ident default_facade_class_ref = ClassName
            ident facade_base_decl_name = FacadeBaseClassName
            ident facade_base_default_base_name = FacadeBaseClassName
            ident facade_base_current_base_name = FacadeBaseClassName
            ident facade_base_working_base_name = FacadeBaseClassName
            ident current_facade_class_decl_name = CurrentFacadeClassName
            ident current_facade_class_ref = CurrentFacadeClassName
            ident working_facade_class_decl_name = WorkingFacadeClassName
            ident working_facade_class_ref = WorkingFacadeClassName
            ident tx_groups_for_index_name = TxGroupsParamName
            ident tx_groups_for_map_name = TxGroupsParamName
            ident tx_groups_for_class_index_name = TxGroupsParamName
            ident tx_groups_for_class_map_name = TxGroupsParamName
            ident tx_groups_for_manager_name = TxGroupsParamName
            ident tx_groups_for_slots_name = TxGroupsParamName
            ident lifecycle_definition_name = LifecycleDefinitionParamName
            ident annotations_name = AnnotationsParamName
            external lifecycle_field_names = LifecycleFieldNames
        }

        apply state_slots
            from field: PlainFields
            where FieldOwner == ClassId
            using PlainStateSlotContributions

        apply binding_state_slots
            from field: BindingFields
            where FieldOwner == ClassId
            using BindingStateSlotContributions

        apply owned_current_state_slots
            from field: OwnedFields
            where FieldOwner == ClassId
            using OwnedCurrentStateSlotContributions

        apply owned_working_state_slots
            from field: OwnedFields
            where FieldOwner == ClassId
            using OwnedWorkingStateSlotContributions

        apply owned_staged_state_slots
            from field: OwnedFields
            where FieldOwner == ClassId
            using OwnedStagedStateSlotContributions

        apply managed_current_state_slots
            from field: ManagedFields
            where FieldOwner == ClassId
            using ManagedCurrentStateSlotContributions

        apply transient_current_state_slots
            from field: TransientFields
            where FieldOwner == ClassId
            using TransientCurrentStateSlotContributions

        apply managed_working_state_slots
            from field: ManagedFields
            where FieldOwner == ClassId
            using ManagedWorkingStateSlotContributions

        apply transient_working_state_slots
            from field: TransientFields
            where FieldOwner == ClassId
            using TransientWorkingStateSlotContributions

        apply retained_initvar_state_slots
            from initvar: RetainedInitVars
            where FieldOwner == ClassId
            using RetainedInitVarStateSlotContributions

        apply managed_staged_state_slots
            from field: ManagedFields
            where FieldOwner == ClassId
            using ManagedStagedStateSlotContributions

        apply transaction_manager_param
            using TransactionManagerInitParamContributions

        apply commit_order_key_fallback
            using CommitOrderKeyFallbackContributions

        apply requires_validation_fallback
            using RequiresValidationFallbackContributions

        apply validate_commit_fallback
            using ValidateCommitFallbackContributions

        apply before_commit_fallback
            using BeforeCommitFallbackContributions

        apply prepare_commit_dispatch_fallback
            using PrepareCommitDispatchFallbackContributions

        apply commit_dispatch_fallback
            using CommitDispatchFallbackContributions

        apply after_commit_fallback
            using AfterCommitFallbackContributions

        apply rollback_dispatch_fallback
            using RollbackDispatchFallbackContributions

        apply after_rollback_fallback
            using AfterRollbackFallbackContributions

        apply commit_order_key_helpers
            from tx_group: TxGroups
            where TxOwner == ClassId
            using CommitOrderKeyHelperContributions

        apply requires_validation_helpers
            from tx_group: TxGroups
            where TxOwner == ClassId
            using RequiresValidationHelperContributions

        apply validate_commit_helpers
            from tx_group: TxGroups
            where TxOwner == ClassId
            using ValidateCommitHelperContributions

        apply before_commit_helpers
            from tx_group: TxGroups
            where TxOwner == ClassId
            using BeforeCommitHelperContributions

        apply after_commit_helpers
            from tx_group: TxGroups
            where TxOwner == ClassId
            using AfterCommitHelperContributions

        apply after_rollback_helpers
            from tx_group: TxGroups
            where TxOwner == ClassId
            using AfterRollbackHelperContributions

        apply commit_order_key_dispatch
            from tx_group: TxGroups
            where TxOwner == ClassId
            using CommitOrderKeyDispatchContributions

        apply requires_validation_dispatch
            from tx_group: TxGroups
            where TxOwner == ClassId
            using RequiresValidationDispatchContributions

        apply validate_commit_dispatch
            from tx_group: TxGroups
            where TxOwner == ClassId
            using ValidateCommitDispatchContributions

        apply before_commit_dispatch
            from tx_group: TxGroups
            where TxOwner == ClassId
            using BeforeCommitDispatchContributions

        apply after_commit_dispatch
            from tx_group: TxGroups
            where TxOwner == ClassId
            using AfterCommitDispatchContributions

        apply after_rollback_dispatch
            from tx_group: TxGroups
            where TxOwner == ClassId
            using AfterRollbackDispatchContributions

        apply classvars
            from field: ClassVarFields
            where FieldOwner == ClassId
            using ClassVarDefaultContributions

        apply commit_order_keys
            from method: CommitOrderKeyProviders
            where MethodOwner == ClassId
            using CommitOrderKeyContributions

        apply validation_flags
            from method: CommitValidators
            where MethodOwner == ClassId
            using RequiresValidationContributions

        apply validators
            from method: CommitValidators
            where MethodOwner == ClassId
            using ValidateCommitContributions

        apply before_commit_hooks
            from method: BeforeCommitHooks
            where MethodOwner == ClassId
            using BeforeCommitHookContributions

        apply after_commit_hooks
            from method: AfterCommitHooks
            where MethodOwner == ClassId
            using AfterCommitHookContributions

        apply after_rollback_hooks
            from method: AfterRollbackHooks
            where MethodOwner == ClassId
            using AfterRollbackHookContributions

        apply plain_init_params
            from field: PlainFields
            where FieldOwner == ClassId
            using PlainInitParamContributions

        apply binding_init_params
            from field: BindingFields
            where FieldOwner == ClassId
            using BindingInitParamContributions

        apply owned_init_params
            from field: OwnedFields
            where FieldOwner == ClassId
            using OwnedInitParamContributions

        apply initvar_params
            from field: InitVarFields
            where FieldOwner == ClassId
            using InitVarParamContributions

        apply managed_init_params
            from field: ManagedFields
            where FieldOwner == ClassId
            using ManagedInitParamContributions

        apply transient_init_params
            from field: TransientFields
            where FieldOwner == ClassId
            using TransientInitParamContributions

        apply initvar_local_defaults
            from field: InitVarFields
            where FieldOwner == ClassId
            using InitVarLocalDefaultContributions

        apply plain_init_assignments
            from field: PlainFields
            where FieldOwner == ClassId
            using PlainInitAssignmentContributions

        apply binding_init_assignments
            from field: BindingFields
            where FieldOwner == ClassId
            using BindingInitAssignmentContributions

        apply owned_current_init_assignments
            from field: OwnedFields
            where FieldOwner == ClassId
            using OwnedCurrentInitAssignmentContributions

        apply managed_current_init_assignments
            from field: ManagedFields
            where FieldOwner == ClassId
            using ManagedCurrentInitAssignmentContributions

        apply transient_current_init_assignments
            from field: TransientFields
            where FieldOwner == ClassId
            using TransientCurrentInitAssignmentContributions

        apply managed_working_init_assignments
            from field: ManagedFields
            where FieldOwner == ClassId
            using ManagedWorkingInitAssignmentContributions

        apply transient_working_init_assignments
            from field: TransientFields
            where FieldOwner == ClassId
            using TransientWorkingInitAssignmentContributions

        apply owned_working_init_assignments
            from field: OwnedFields
            where FieldOwner == ClassId
            using OwnedWorkingInitAssignmentContributions

        apply retained_initvar_state_assignments
            from initvar: RetainedInitVars
            where FieldOwner == ClassId
            using RetainedInitVarStateAssignmentContributions

        apply owned_staged_init_assignments
            from field: OwnedFields
            where FieldOwner == ClassId
            using OwnedStagedInitAssignmentContributions

        apply managed_staged_init_assignments
            from field: ManagedFields
            where FieldOwner == ClassId
            using ManagedStagedInitAssignmentContributions

        apply default_factory_evals
            from step: DefaultFactoryEvaluationSteps
            where EvalOwner == ClassId
            using DefaultFactoryEvalContributions

        apply default_factory_args
            from dep: DefaultFactoryDependencies
            where DependencyOwner == ClassId
            using DefaultFactoryArgContributions

        apply plain_properties
            from field: PlainFields
            where FieldOwner == ClassId
            using PlainPropertyContributions

        apply binding_properties
            from field: BindingFields
            where FieldOwner == ClassId
            using BindingPropertyContributions

        apply owned_default_properties
            from field: IndexedOwnedFields
            where FieldOwner == ClassId
            using OwnedDefaultFacadePropertyContributions

        apply managed_default_properties
            from field: IndexedTransactionalFields
            where FieldOwner == ClassId
            using ManagedDefaultFacadePropertyContributions

        apply transient_default_properties
            from field: IndexedTransientFields
            where FieldOwner == ClassId
            using TransientDefaultFacadePropertyContributions

        apply managed_current_properties
            from field: IndexedTransactionalFields
            where FieldOwner == ClassId
            using ManagedCurrentFacadePropertyContributions

        apply transient_current_properties
            from field: TransientFields
            where FieldOwner == ClassId
            using TransientCurrentPropertyContributions

        apply owned_current_properties
            from field: IndexedOwnedFields
            where FieldOwner == ClassId
            using OwnedCurrentFacadePropertyContributions

        apply managed_working_properties
            from field: IndexedTransactionalFields
            where FieldOwner == ClassId
            using ManagedWorkingFacadePropertyContributions

        apply owned_working_properties
            from field: IndexedOwnedFields
            where FieldOwner == ClassId
            using OwnedWorkingFacadePropertyContributions

        apply transient_working_properties
            from field: IndexedTransientFields
            where FieldOwner == ClassId
            using TransientWorkingFacadePropertyContributions

        apply transient_default_working_factory_args
            from arg: TransientWorkingFactoryArgs
            where WorkingFactoryArgOwner == ClassId
            using TransientDefaultWorkingFactoryArgContributions

        apply transient_working_working_factory_args
            from arg: TransientWorkingFactoryArgs
            where WorkingFactoryArgOwner == ClassId
            using TransientWorkingWorkingFactoryArgContributions

        apply apply_prepared_commit_helpers
            from tx_group: TxGroups
            where TxOwner == ClassId
            using ApplyPreparedCommitFieldsContributions

        apply prepare_commit_helpers
            from tx_group: TxGroups
            where TxOwner == ClassId
            using PrepareCommitFieldsContributions

        apply rollback_helpers
            from tx_group: TxGroups
            where TxOwner == ClassId
            using RollbackFieldsContributions

        apply prepare_commit_dispatch
            from tx_group: TxGroups
            where TxOwner == ClassId
            using PrepareCommitDispatchContributions

        apply apply_prepared_commit_dispatch
            from tx_group: TxGroups
            where TxOwner == ClassId
            using ApplyPreparedCommitDispatchContributions

        apply rollback_dispatch
            from tx_group: TxGroups
            where TxOwner == ClassId
            using RollbackDispatchContributions

        apply managed_prepare_commit
            from field: IndexedTransactionalFields
            where FieldOwner == ClassId
            using ManagedPrepareCommitContributions

        apply managed_apply_prepared_commit
            from field: IndexedTransactionalFields
            where FieldOwner == ClassId
            using ManagedApplyPreparedCommitContributions

        apply owned_apply_prepared_commit
            from field: IndexedOwnedFields
            where FieldOwner == ClassId
            using OwnedApplyPreparedCommitContributions

        apply transient_apply_prepared_commit
            from field: IndexedTransientFields
            where FieldOwner == ClassId
            using TransientApplyPreparedCommitContributions

        apply managed_rollback
            from field: IndexedTransactionalFields
            where FieldOwner == ClassId
            using ManagedRollbackContributions

        apply owned_rollback
            from field: IndexedOwnedFields
            where FieldOwner == ClassId
            using OwnedRollbackContributions

        apply transient_rollback
            from field: IndexedTransientFields
            where FieldOwner == ClassId
            using TransientRollbackContributions

        apply owned_prepare_commit
            from field: IndexedOwnedFields
            where FieldOwner == ClassId
            using OwnedPrepareCommitContributions
    }

    assembly LifecycleModule = ModuleProduction

}
